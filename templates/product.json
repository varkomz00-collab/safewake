color 0.3s ease;\n      text-align: left;\n    }\n    \/* Remove hover background change *\/\n    .collapsible-trigger:hover {\n      background-color: inherit;\n    }\n    .collapsible-trigger:focus {\n      outline: none;\n    }\n    \/* Icon rotation on open and adjusted spacing *\/\n    .collapsible-trigger__icon {\n      transition: transform 0.3s ease;\n      margin-right: 20px;\n    }\n    .collapsible-trigger[aria-expanded=\"true\"] .collapsible-trigger__icon {\n      transform: rotate(180deg);\n    }\n    \/* Content container with slide-down animation *\/\n    .size-guide-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.5s ease;\n      border-top: 1px solid #ddd;\n      padding: 0 15px;\n    }\n    \/* When open, allow enough max-height and add vertical padding *\/\n    .size-guide-content.open {\n      max-height: 1000px;\n      padding-top: 15px;\n      padding-bottom: 15px;\n    }\n    \/* Table styling – base font size and padding *\/\n    .size-guide-content table {\n      width: 100%;\n      border-collapse: collapse;\n      text-align: center;\n      font-size: 12px; \/* Updated base font size for table cells *\/\n      margin-bottom: 20px; \/* Add some spacing between tables *\/\n    }\n    .size-guide-content th,\n    .size-guide-content td {\n      padding: 5px;  \/* reduced padding *\/\n      border: 1px solid #ddd;\n      text-align: center;\n    }\n    \/* Ensure table header text is black and slightly bigger than cell text *\/\n    .size-guide-content th {\n      color: black;\n      font-size: 13px; \/* Header text size is one size greater than table cells *\/\n    }\n    .size-guide-content thead tr {\n      background-color: #f8f8f8;\n    }\n    \/* Optional: Style the table caption *\/\n    .size-guide-content caption {\n      caption-side: top;\n      font-weight: bold;\n      padding-bottom: 8px;\n      font-size: 12px;\n      text-align: left;\n    }\n    \/* Media Query for desktop view *\/\n    @media (min-width: 768px) {\n      .size-guide-content table {\n        font-size: 12px;\n      }\n    }\n  <\/style>\n<\/head>\n<body>\n  <div class=\"size-guide-container\">\n    <!-- Collapsible Trigger Button with Unique ID -->\n    <button type=\"button\"\n            id=\"sizeChartTrigger1\"\n            class=\"collapsible-trigger\"\n            aria-controls=\"sizeChartContent1\"\n            aria-expanded=\"false\">\n      Binding Size Chart\n      <span class=\"collapsible-trigger__icon\" role=\"presentation\">\n        <svg aria-hidden=\"true\"\n             focusable=\"false\"\n             role=\"presentation\"\n             class=\"icon icon--wide icon-chevron-down\"\n             viewBox=\"0 0 28 16\"\n             style=\"width: 16px; height: auto;\">\n          <path d=\"M1.57 1.59L14.33 14.36 27.1 1.59\"\n                stroke-width=\"2\"\n                stroke=\"currentColor\"\n                fill=\"none\"><\/path>\n        <\/svg>\n      <\/span>\n    <\/button>\n    \n    <!-- Collapsible Content with Unique ID -->\n    <div id=\"sizeChartContent1\" class=\"size-guide-content\">\n      <!-- Closed Toe\/System Boot Bindings Table -->\n      <div class=\"table-responsive dynamic\">\n        <table cellpadding=\"5\">\n          <caption>Closed Toe\/System Boot Bindings<\/caption>\n          <thead>\n            <tr>\n              <th>Size (US)<\/th>\n              <th>Size (EU)<\/th>\n            <\/tr>\n          <\/thead>\n          <tbody>\n            <tr>\n              <td>OSFA<\/td>\n              <td>One Size Fits All<\/td>\n            <\/tr>\n            <tr>\n              <td>6 US<\/td>\n              <td>38 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>7 US<\/td>\n              <td>39 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>8 US<\/td>\n              <td>40.5 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>9 US<\/td>\n              <td>42 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>10 US<\/td>\n              <td>43 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>11 US<\/td>\n              <td>44.5 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>12 US<\/td>\n              <td>46 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>13 US<\/td>\n              <td>47 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>13\/14 US<\/td>\n              <td>47 EU<\/td>\n            <\/tr>\n          <\/tbody>\n        <\/table>\n      <\/div>\n      \n      <!-- Free Range Bindings Table -->\n      <div class=\"table-responsive dynamic\">\n        <table cellpadding=\"5\">\n          <caption>Free Range Bindings<\/caption>\n          <thead>\n            <tr>\n              <th>Size (US)<\/th>\n              <th>Size (EU)<\/th>\n            <\/tr>\n          <\/thead>\n          <tbody>\n            <tr>\n              <td>4–8 US<\/td>\n              <td>36–41.5 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>7\/8 US<\/td>\n              <td>39–40.5 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>7–10.5 US<\/td>\n              <td>39–44.5 EU<\/td>\n            <\/tr>\n          <\/tbody>\n        <\/table>\n      <\/div>\n      \n      <!-- Women's Bindings Table -->\n      <div class=\"table-responsive dynamic\">\n        <table cellpadding=\"5\">\n          <caption>Women's Bindings<\/caption>\n          <thead>\n            <tr>\n              <th>Size (US)<\/th>\n              <th>Size (EU)<\/th>\n            <\/tr>\n          <\/thead>\n          <tbody>\n            <tr>\n              <td>6 (W) US<\/td>\n              <td>38 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>7 (W) US<\/td>\n              <td>38 EU<\/td>\n            <\/tr>\n            <tr>\n              <td>8 (W) US<\/td>\n              <td>39 EU<\/td>\n            <\/tr>\n          <\/tbody>\n        <\/table>\n      <\/div>\n      \n    <\/div>\n  <\/div>\n  \n  <script>\n    \/\/ Wrap the code in DOMContentLoaded to ensure it always runs\n    document.addEventListener(\"DOMContentLoaded\", function() {\n      var trigger1 = document.getElementById('sizeChartTrigger1');\n      var content1 = document.getElementById('sizeChartContent1');\n      trigger1.addEventListener('click', function() {\n        var isExpanded = this.getAttribute('aria-expanded') === 'true';\n        if (isExpanded) {\n          this.setAttribute('aria-expanded', 'false');\n          content1.classList.remove('open');\n        } else {\n          this.setAttribute('aria-expanded', 'true');\n          content1.classList.add('open');\n        }\n      });\n    });\n  <\/script>\n<\/body>\n<\/html>","show_in_quickbuy":false}},"description":{"type":"description","settings":{"show_in_tab":false,"open_tab":false,"icon":"","show_in_quickbuy":false}}},"block_order":["title","vendor","divider","price","6723713d-ca46-48c8-9fbf-9a05ccdc3a3d","variant-picker","buy-buttons","custom_liquid_mMbna3","custom_liquid_xemiPz","custom_liquid_6KN4FA","description"],"settings":{"show_breadcrumbs":true,"show_location_underneath":false,"inventory_transfers_enable":true,"enable_sticky_columns":false,"gallery_size":"medium","gallery_layout":"carousel-under","enable_zoom":true,"show_alt_text":false,"alt_text_icon":"","enable_video_autoplay":false,"enable_video_looping":false,"enable_media_grouping":false,"media_grouping_option":"Color,Colour,Couleur,Farbe"}},"related-products":{"type":"related-products","settings":{"title":"You may also like","show_vendor":false,"grid":4}},"c781d5e2-2dcc-43f5-ac61-c856fa65bae4":{"type":"featured-collection","settings":{"title":"Best Sellers","collection":"all","show_vendor":false,"enable_carousel":true,"grid":5,"rows":1,"color_scheme":"1","show_view_all":true,"full_width":true}}},"order":["main","related-products","c781d5e2-2dcc-43f5-ac61-c856fa65bae4"]}