{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-chroma-product-{{ ai_gen_id }} {
    background-color: #000000;
    padding: 48px 20px;
  }

  .ai-chroma-product__container-{{ ai_gen_id }} {
    max-width: 960px;
    margin: 0 auto;
  }

  .ai-chroma-product__card-{{ ai_gen_id }} {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .ai-chroma-product__images-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-chroma-product__main-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
  }

  .ai-chroma-product__main-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 6px;
  }

  .ai-chroma-product__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
  }

  .ai-chroma-product__image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-chroma-product__thumbnails-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-chroma-product__thumbnail-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .ai-chroma-product__thumbnail-{{ ai_gen_id }}:hover {
    border-color: #0AA3FF;
  }

  .ai-chroma-product__details-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-chroma-product__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 9999px;
    color: #B9C4CF;
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
    width: fit-content;
  }

  .ai-chroma-product__label-{{ ai_gen_id }} {
    color: #B9C4CF;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .ai-chroma-product__title-{{ ai_gen_id }} {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 8px;
    text-shadow: 0 0 16px rgba(10, 163, 255, 0.35), 0 0 32px rgba(10, 163, 255, 0.15);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .ai-chroma-product__price-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
  }

  .ai-chroma-product__price-current-{{ ai_gen_id }} {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 600;
  }

  .ai-chroma-product__price-compare-{{ ai_gen_id }} {
    color: #B9C4CF;
    font-size: 18px;
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-chroma-product__cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 8px;
  }

  .ai-chroma-product__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 28px;
    background-color: #0AA3FF;
    color: #000000;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    text-align: center;
    width: fit-content;
  }

  .ai-chroma-product__button-{{ ai_gen_id }}:hover {
    background-color: #3db8ff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(10, 163, 255, 0.25);
  }

  .ai-chroma-product__urgency-{{ ai_gen_id }} {
    color: #B9C4CF;
    font-size: 10px;
  }

  .ai-chroma-product__description-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .ai-chroma-product__feature-{{ ai_gen_id }} {
    color: #B9C4CF;
    font-size: 13px;
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .ai-chroma-product__feature-{{ ai_gen_id }}:before {
    content: '•';
    position: absolute;
    left: 4px;
    color: #0AA3FF;
  }

  @media screen and (min-width: 750px) {
    .ai-chroma-product__card-{{ ai_gen_id }} {
      grid-template-columns: 320px 1fr;
      gap: 36px;
      padding: 32px 28px;
    }

    .ai-chroma-product__main-image-wrapper-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-chroma-product__thumbnails-{{ ai_gen_id }} {
      justify-content: flex-start;
    }

    .ai-chroma-product__details-{{ ai_gen_id }} {
      gap: 14px;
    }

    .ai-chroma-product__title-{{ ai_gen_id }} {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .ai-chroma-product__price-current-{{ ai_gen_id }} {
      font-size: 26px;
    }

    .ai-chroma-product__cta-wrapper-{{ ai_gen_id }} {
      margin-bottom: 10px;
    }

    .ai-chroma-product__description-{{ ai_gen_id }} {
      padding-top: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-chroma-product-{{ ai_gen_id }} {
      padding: 32px 16px;
    }

    .ai-chroma-product__card-{{ ai_gen_id }} {
      padding: 20px 16px;
      gap: 20px;
    }

    .ai-chroma-product__details-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-chroma-product__title-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 6px;
    }

    .ai-chroma-product__price-current-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-chroma-product__price-compare-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-chroma-product__button-{{ ai_gen_id }} {
      width: 100%;
      max-width: 280px;
    }

    .ai-chroma-product__cta-wrapper-{{ ai_gen_id }} {
      margin-bottom: 6px;
    }

    .ai-chroma-product__description-{{ ai_gen_id }} {
      padding-top: 6px;
    }
  }
{% endstyle %}

<div class="ai-chroma-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-chroma-product__container-{{ ai_gen_id }}">
    <div class="ai-chroma-product__card-{{ ai_gen_id }}">
      <div class="ai-chroma-product__images-{{ ai_gen_id }}">
        <div class="ai-chroma-product__main-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.chroma_product != blank and block.settings.chroma_product.featured_image %}
            <img
              src="{{ block.settings.chroma_product.featured_image | image_url: width: 640 }}"
              alt="{{ block.settings.chroma_product.featured_image.alt | escape }}"
              class="ai-chroma-product__main-image-{{ ai_gen_id }}"
              loading="lazy"
              width="320"
              height="320"
            >
          {% else %}
            <div class="ai-chroma-product__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if block.settings.chroma_product != blank and block.settings.chroma_product.media.size > 1 %}
          <div class="ai-chroma-product__thumbnails-{{ ai_gen_id }}">
            {% for media in block.settings.chroma_product.media limit: 4 %}
              {% if media.media_type == 'image' %}
                <img
                  src="{{ media | image_url: width: 120 }}"
                  alt="{{ media.alt | escape }}"
                  class="ai-chroma-product__thumbnail-{{ ai_gen_id }}"
                  loading="lazy"
                  width="60"
                  height="60"
                >
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="ai-chroma-product__details-{{ ai_gen_id }}">
        <div class="ai-chroma-product__pill-{{ ai_gen_id }}">
          {{ block.settings.pill_text }}
        </div>

        <div>
          <div class="ai-chroma-product__label-{{ ai_gen_id }}">
            {{ block.settings.product_label }}
          </div>
          <h2 class="ai-chroma-product__title-{{ ai_gen_id }}">
            {% if block.settings.chroma_product != blank %}
              {{ block.settings.chroma_product.title }}
            {% else %}
              {{ block.settings.product_name }}
            {% endif %}
          </h2>
        </div>

        {% if block.settings.chroma_product != blank %}
          <div class="ai-chroma-product__price-{{ ai_gen_id }}">
            <span class="ai-chroma-product__price-current-{{ ai_gen_id }}">
              {{ block.settings.chroma_product.price | money }}
            </span>
            {% if block.settings.chroma_product.compare_at_price > block.settings.chroma_product.price %}
              <span class="ai-chroma-product__price-compare-{{ ai_gen_id }}">
                {{ block.settings.chroma_product.compare_at_price | money }}
              </span>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-chroma-product__cta-wrapper-{{ ai_gen_id }}">
          {% if block.settings.chroma_product != blank %}
            <a
              href="{{ block.settings.chroma_product.url }}"
              class="ai-chroma-product__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% else %}
            <a
              href="#"
              class="ai-chroma-product__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
          <div class="ai-chroma-product__urgency-{{ ai_gen_id }}">
            {{ block.settings.urgency_text }}
          </div>
        </div>

        <div class="ai-chroma-product__description-{{ ai_gen_id }}">
          {% if block.settings.feature_1 != blank %}
            <div class="ai-chroma-product__feature-{{ ai_gen_id }}">
              {{ block.settings.feature_1 }}
            </div>
          {% endif %}
          {% if block.settings.feature_2 != blank %}
            <div class="ai-chroma-product__feature-{{ ai_gen_id }}">
              {{ block.settings.feature_2 }}
            </div>
          {% endif %}
          {% if block.settings.feature_3 != blank %}
            <div class="ai-chroma-product__feature-{{ ai_gen_id }}">
              {{ block.settings.feature_3 }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

