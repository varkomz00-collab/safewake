{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-safesnow-intro-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, 
      #000000 0%, 
      #1a1d24 15%,
      #2a3340 25%,
      #4a5568 35%,
      #6b7280 45%,
      #8b95a8 55%,
      #a8b0bc 65%,
      #c4cad4 75%,
      #d8dde3 85%,
      #e8ebef 92%,
      #f5f7f9 96%,
      #ffffff 100%
    );
    overflow: hidden;
    padding: {{ block.settings.padding_top }}px 24px {{ block.settings.padding_bottom }}px;
  }

  .ai-safesnow-canvas-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .ai-safesnow-haze-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 25%;
    background: linear-gradient(to top, 
      rgba(255, 255, 255, 0.25) 0%,
      rgba(240, 248, 255, 0.12) 50%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .ai-safesnow-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: 720px;
    text-align: center;
    color: {{ block.settings.text_color }};
  }

  .ai-safesnow-eyebrow-{{ ai_gen_id }} {
    display: inline-block;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.6;
  }

  .ai-safesnow-headline-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 32px;
    letter-spacing: -0.03em;
  }

  .ai-safesnow-description-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: {{ block.settings.description_size }}px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0 0 40px;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-safesnow-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 36px;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text_color }};
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 980px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 72px;
    letter-spacing: -0.01em;
  }

  .ai-safesnow-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover }};
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-safesnow-features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  .ai-safesnow-feature-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: {{ block.settings.feature_size }}px;
    font-weight: 400;
    opacity: 0.7;
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: {{ block.settings.feature_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-safesnow-intro-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 20px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-safesnow-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_size }}px * 0.85);
      margin-bottom: 12px;
    }

    .ai-safesnow-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.5);
      margin-bottom: 24px;
    }

    .ai-safesnow-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
      margin-bottom: 32px;
    }

    .ai-safesnow-cta-{{ ai_gen_id }} {
      padding: 12px 32px;
      font-size: calc({{ block.settings.button_size }}px * 0.95);
      margin-bottom: 56px;
    }

    .ai-safesnow-feature-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.feature_size }}px * 0.95);
    }
  }
{% endstyle %}

<safe-snow-intro-{{ ai_gen_id }} class="ai-safesnow-intro-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <canvas class="ai-safesnow-canvas-{{ ai_gen_id }}" data-snow-count="{{ block.settings.snow_count }}"></canvas>
  <div class="ai-safesnow-haze-{{ ai_gen_id }}"></div>
  
  <div class="ai-safesnow-content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-safesnow-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-safesnow-headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-safesnow-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.cta_text != blank and block.settings.cta_link != blank %}
      <a href="{{ block.settings.cta_link }}" class="ai-safesnow-cta-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    {% endif %}

    {% if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank %}
      <div class="ai-safesnow-features-{{ ai_gen_id }}">
        {% if block.settings.feature_1 != blank %}
          <div class="ai-safesnow-feature-{{ ai_gen_id }}">{{ block.settings.feature_1 }}</div>
        {% endif %}
        {% if block.settings.feature_2 != blank %}
          <div class="ai-safesnow-feature-{{ ai_gen_id }}">{{ block.settings.feature_2 }}</div>
        {% endif %}
        {% if block.settings.feature_3 != blank %}
          <div class="ai-safesnow-feature-{{ ai_gen_id }}">{{ block.settings.feature_3 }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</safe-snow-intro-{{ ai_gen_id }}>

<script>
(function() {
  class SafeSnowIntro{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.canvas = this.querySelector('.ai-safesnow-canvas-{{ ai_gen_id }}');
      this.ctx = this.canvas.getContext('2d');
      this.snowflakes = [];
      this.animationId = null;
    }

    connectedCallback() {
      this.initCanvas();
      this.createSnowflakes();
      this.animate();
      window.addEventListener('resize', this.handleResize.bind(this));
    }

    disconnectedCallback() {
      if (this.animationId) {
        cancelAnimationFrame(this.animationId);
      }
      window.removeEventListener('resize', this.handleResize.bind(this));
    }

    initCanvas() {
      this.canvas.width = this.offsetWidth;
      this.canvas.height = this.offsetHeight;
    }

    handleResize() {
      this.initCanvas();
    }

    createSnowflakes() {
      const count = parseInt(this.canvas.dataset.snowCount) || 80;
      this.snowflakes = [];
      
      for (let i = 0; i < count; i++) {
        const depth = Math.random();
        const size = depth < 0.3 ? Math.random() * 1.5 + 0.5 : 
                     depth < 0.7 ? Math.random() * 2 + 1.5 : 
                     Math.random() * 2.5 + 2;
        
        this.snowflakes.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          radius: size,
          speed: (1 - depth) * 0.6 + 0.3,
          drift: (Math.random() - 0.5) * 0.8,
          opacity: depth < 0.3 ? Math.random() * 0.15 + 0.05 : 
                   depth < 0.7 ? Math.random() * 0.25 + 0.15 : 
                   Math.random() * 0.35 + 0.25,
          blur: depth < 0.3 ? 2 : depth < 0.7 ? 1 : 0
        });
      }
    }

    animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      this.snowflakes.forEach((flake) => {
        this.ctx.save();
        
        if (flake.blur > 0) {
          this.ctx.filter = `blur(${flake.blur}px)`;
        }
        
        this.ctx.beginPath();
        this.ctx.arc(flake.x, flake.y, flake.radius, 0, Math.PI * 2);
        this.ctx.fillStyle = `rgba(255, 255, 255, ${flake.opacity})`;
        this.ctx.fill();
        
        this.ctx.restore();

        flake.y += flake.speed;
        flake.x += flake.drift;

        if (flake.y > this.canvas.height + 10) {
          flake.y = -10;
          flake.x = Math.random() * this.canvas.width;
        }

        if (flake.x > this.canvas.width + 10) {
          flake.x = -10;
        } else if (flake.x < -10) {
          flake.x = this.canvas.width + 10;
        }
      });

      this.animationId = requestAnimationFrame(this.animate.bind(this));
    }
  }

  customElements.define('safe-snow-intro-{{ ai_gen_id }}', SafeSnowIntro{{ ai_gen_id }});
})();
</script>

