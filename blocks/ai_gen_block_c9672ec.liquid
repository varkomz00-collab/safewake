{% doc %}
  Thin global brand bar at the very top of the site, styled like Hyperlite’s
  brand strip.

  - Sits above main header on every page.
  - Background: dark/near-black (#202226).
  - Shows SAFEWAKE and SAFESNOW with 32x32 logos.
  - Active brand text: white (#FFFFFF).
  - Inactive brand text: medium grey (#6B7280).
  - Hover text: light grey (#E5E7EB).
  - Extra brand slots (3–5) for future use.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-bar-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    width: 100%;
    padding: {{ block.settings.bar_height }}px 0;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-brand-bar-container-{{ ai_gen_id }} {
    max-width: {{ settings.max_page_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-brand-bar-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
    font-weight: {{ block.settings.font.weight }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    transition: color 0.2s ease, opacity 0.2s ease;
    white-space: nowrap;
  }

  .ai-brand-bar-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
    opacity: 0.9;
  }

  .ai-brand-bar-link-{{ ai_gen_id }}.active {
    color: {{ block.settings.active_text_color }};
  }

  .ai-brand-bar-link-{{ ai_gen_id }}.inactive {
    color: {{ block.settings.inactive_text_color }};
  }

  .ai-brand-bar-logo-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    object-fit: contain;
    background-color: {{ block.settings.placeholder_bg }};
    border-radius: 4px;
  }

  .ai-brand-bar-logo-placeholder-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background-color: {{ block.settings.placeholder_bg }};
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-bar-container-{{ ai_gen_id }} {
      justify-content: center;
      flex-wrap: wrap;
    }

    .ai-brand-bar-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-brand-bar-logo-{{ ai_gen_id }},
    .ai-brand-bar-logo-placeholder-{{ ai_gen_id }} {
      width: 28px;
      height: 28px;
    }
  }
{% endstyle %}

<div class="ai-brand-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-bar-container-{{ ai_gen_id }}">

    {%- comment -%} Brand 1: SAFEWAKE (usually the current site) {%- endcomment -%}
    {% if block.settings.brand_1_text != blank %}
      <a
        href="{{ block.settings.brand_1_url }}"
        class="ai-brand-bar-link-{{ ai_gen_id }} {% if block.settings.brand_1_active %}active{% else %}inactive{% endif %}"
        {% if block.settings.brand_1_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {% if block.settings.brand_1_logo %}
          <img
            src="{{ block.settings.brand_1_logo | image_url: width: 64 }}"
            alt="{{ block.settings.brand_1_text }}"
            class="ai-brand-bar-logo-{{ ai_gen_id }}"
            width="32"
            height="32"
            loading="lazy"
          >
        {% else %}
          <div class="ai-brand-bar-logo-placeholder-{{ ai_gen_id }}"></div>
        {% endif %}
        {{ block.settings.brand_1_text }}
      </a>
    {% endif %}

    {%- comment -%} Brand 2: SAFESNOW (usually other site, opens new tab) {%- endcomment -%}
    {% if block.settings.brand_2_text != blank %}
      <a
        href="{{ block.settings.brand_2_url }}"
        class="ai-brand-bar-link-{{ ai_gen_id }} {% if block.settings.brand_2_active %}active{% else %}inactive{% endif %}"
        {% if block.settings.brand_2_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {% if block.settings.brand_2_logo %}
          <img
            src="{{ block.settings.brand_2_logo | image_url: width: 64 }}"
            alt="{{ block.settings.brand_2_text }}"
            class="ai-brand-bar-logo-{{ ai_gen_id }}"
            width="32"
            height="32"
            loading="lazy"
          >
        {% else %}
          <div class="ai-brand-bar-logo-placeholder-{{ ai_gen_id }}"></div>
        {% endif %}
        {{ block.settings.brand_2_text }}
      </a>
    {% endif %}

    {%- comment -%} Future brands 3–5 (only render if configured) {%- endcomment -%}
    {% if block.settings.brand_3_text != blank %}
      <a
        href="{{ block.settings.brand_3_url }}"
        class="ai-brand-bar-link-{{ ai_gen_id }} inactive"
        {% if block.settings.brand_3_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {% if block.settings.brand_3_logo %}
          <img
            src="{{ block.settings.brand_3_logo | image_url: width: 64 }}"
            alt="{{ block.settings.brand_3_text }}"
            class="ai-brand-bar-logo-{{ ai_gen_id }}"
            width="32"
            height="32"
            loading="lazy"
          >
        {% else %}
          <div class="ai-brand-bar-logo-placeholder-{{ ai_gen_id }}"></div>
        {% endif %}
        {{ block.settings.brand_3_text }}
      </a>
    {% endif %}

    {% if block.settings.brand_4_text != blank %}
      <a
        href="{{ block.settings.brand_4_url }}"
        class="ai-brand-bar-link-{{ ai_gen_id }} inactive"
        {% if block.settings.brand_4_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {% if block.settings.brand_4_logo %}
          <img
            src="{{ block.settings.brand_4_logo | image_url: width: 64 }}"
            alt="{{ block.settings.brand_4_text }}"
            class="ai-brand-bar-logo-{{ ai_gen_id }}"
            width="32"
            height="32"
            loading="lazy"
          >
        {% else %}
          <div class="ai-brand-bar-logo-placeholder-{{ ai_gen_id }}"></div>
        {% endif %}
        {{ block.settings.brand_4_text }}
      </a>
    {% endif %}

    {% if block.settings.brand_5_text != blank %}
      <a
        href="{{ block.settings.brand_5_url }}"
        class="ai-brand-bar-link-{{ ai_gen_id }} inactive"
        {% if block.settings.brand_5_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {% if block.settings.brand_5_logo %}
          <img
            src="{{ block.settings.brand_5_logo | image_url: width: 64 }}"
            alt="{{ block.settings.brand_5_text }}"
            class="ai-brand-bar-logo-{{ ai_gen_id }}"
            width="32"
            height="32"
            loading="lazy"
          >
        {% else %}
          <div class="ai-brand-bar-logo-placeholder-{{ ai_gen_id }}"></div>
        {% endif %}
        {{ block.settings.brand_5_text }}
      </a>
    {% endif %}
  </div>
</div>

