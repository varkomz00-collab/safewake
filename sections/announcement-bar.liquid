{% if section.blocks.size > 0 or section.settings.enable_language_selector or section.settings.enable_country_selector or section.settings.menu != blank %}
  {%- liquid
    assign longest_announcement = 0

    for block in section.blocks
      assign text = block.settings.text | strip_html
      if text.size > longest_announcement
        assign longest_announcement = text.size
      endif
    endfor
  -%}

  <announcement-bar
    id="section-id-{{ section.id }}"
    class="announcement-bar
      {%- if section.blocks.size > 0 %} announcement-bar--with-announcement{% endif -%}
      {%- if longest_announcement > 45 and section.settings.menu != blank %} announcement-bar--tablet-wrap{% endif -%}
    "
    data-cc-animate
  >
    {% style %}
      #section-id-{{ section.id }} {
        --bg-color: {{ section.settings.announcement_bar_col }};
        --heading-color: {{ section.settings.announcement_text_col.rgb }};
        --text-color: {{ section.settings.announcement_text_col.rgb }};
        --link-color: {{ section.settings.announcement_text_col.rgb }};
        --announcement-font-size: {{ section.settings.message_font_size }}px;

        display: block;
        background-color: var(--sw-surface-paper, var(--bg-color));
        color: rgb(var(--text-color));
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      #section-id-{{ section.id }} .container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        max-width: 1280px;
        margin: 0 auto;
        padding-inline: 12px;
        padding-block: 2px;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.02em;
      }

      /* Symmetrical desktop layout */
      #section-id-{{ section.id }} .announcement-bar__left,
      #section-id-{{ section.id }} .announcement-bar__right {
        flex: 1 1 0;
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
        white-space: nowrap;
        opacity: 0.7;
      }

      #section-id-{{ section.id }} .announcement-bar__left {
        justify-content: flex-start;
      }

      #section-id-{{ section.id }} .announcement-bar__right {
        justify-content: flex-end;
      }

      #section-id-{{ section.id }} .announcement-bar__middle {
        flex: 0 0 auto;
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      #section-id-{{ section.id }} .announcement-bar__announcements {
        width: 100%;
        max-width: 640px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #section-id-{{ section.id }} .announcement {
        width: 100%;
      }

      #section-id-{{ section.id }} .announcement--inactive {
        display: none;
      }

      #section-id-{{ section.id }} .announcement__text {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 3px 12px;
        border-radius: var(--sw-radius-pill, 999px);
        background: rgba(255, 255, 255, 0.05);
        color: rgb(var(--text-color));
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.02em;
        line-height: 1.4;
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
        max-height: 2.4em;
        cursor: pointer;
        transition: background var(--sw-transition-smooth, 150ms ease);
        text-align: center;
      }

      #section-id-{{ section.id }} .announcement__text:hover {
        background: rgba(255, 255, 255, 0.08);
      }

      #section-id-{{ section.id }}.announcement-bar--tablet-wrap .announcement__text {
        text-overflow: unset;
      }

      #section-id-{{ section.id }}.announcement-bar--expanded .announcement__text {
        white-space: normal;
        max-height: none;
      }

      #section-id-{{ section.id }} .announcement__text a {
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      #section-id-{{ section.id }} .announcement__dismiss {
        margin-left: auto;
        width: 20px;
        height: 20px;
        border-radius: var(--sw-radius-pill, 999px);
        border: none;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        cursor: pointer;
        flex-shrink: 0;
        font-size: 14px;
        line-height: 1;
        opacity: 0.5;
        transition: background var(--sw-transition-smooth, 150ms ease),
                    opacity var(--sw-transition-smooth, 150ms ease);
      }

      #section-id-{{ section.id }} .announcement__dismiss:hover {
        background: rgba(255, 255, 255, 0.08);
        opacity: 1;
      }

      #section-id-{{ section.id }} .inline-menu__link {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.02em;
        opacity: 0.6;
        text-decoration: none;
        transition: opacity var(--sw-transition-smooth, 150ms ease);
      }

      #section-id-{{ section.id }} .inline-menu__link:hover {
        opacity: 1;
      }

      #section-id-{{ section.id }} .header-localization {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.02em;
      }

      @media (min-width: 768px) {
        #section-id-{{ section.id }} .container {
          padding-inline: 20px;
          padding-block: 3px;
        }
      }

      @media (max-width: 767.98px) {
        #section-id-{{ section.id }} .container {
          gap: 6px;
          padding-inline: 10px;
          padding-block: 2px;
        }

        #section-id-{{ section.id }} .announcement__text {
          padding-inline: 9px;
        }

        #section-id-{{ section.id }} .announcement-bar__middle {
          flex: 1 1 auto;
          justify-content: center;
        }

        #section-id-{{ section.id }} .announcement-bar__left,
        #section-id-{{ section.id }} .announcement-bar__right {
          display: none;
        }
      }
    {% endstyle %}

    <div class="container container--no-max">
      <div class="announcement-bar__left desktop-only">
        {% if section.settings.show_social_icons %}
          {%- render 'social-media', icon: settings.social_custom_icon, icon_height: 20 -%}
        {% endif %}
      </div>

      <div class="announcement-bar__middle">
        {%- if section.blocks.size > 0 -%}
          <div class="announcement-bar__announcements">
            {%- assign first_announcement_found = false -%}
            {%- for block in section.blocks -%}
              {%- liquid
                if block.settings.show_countdown
                  assign now = "now" | date: '%Y-%m-%dT%H:%M'

                  if block.settings.end_date != blank
                    assign end_date = block.settings.end_date
                    if block.settings.end_time != blank
                      assign end_date = end_date | append: 'T' | append: block.settings.end_time
                    endif
                    assign end_date = end_date | date: '%Y-%m-%dT%H:%M'
                  else
                    assign now_split = now | split: 'T'
                    assign end_date = now_split.first | append: 'T23:59' | date: '%Y-%m-%dT%H:%M'
                  endif

                  if block.settings.hide_on_end and end_date < now
                    continue
                  endif
                endif
              -%}

              <div class="announcement{% if first_announcement_found %} announcement--inactive{% endif %}" {{ block.shopify_attributes }}>
                {%- assign first_announcement_found = true -%}
                <div class="announcement__text" data-announcement-toggle>
                  {{ block.settings.text }}

                  {% if block.settings.show_countdown and end_date > now %}
                    <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
                    <span class="countdown-font-{{ block.settings.number_font }} announcement-text-separation-{{ block.settings.countdown_separator }}">
                      {% render 'countdown-timer',
                        end_date: block.settings.end_date,
                        end_time: block.settings.end_time,
                        end_midnight: true,
                        hide_on_end: true,
                        show_labels: true
                      %}
                    </span>
                  {% endif %}

                  <button
                    type="button"
                    class="announcement__dismiss"
                    data-announcement-dismiss
                    aria-label="Dismiss announcement"
                  >
                    &times;
                  </button>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="announcement-bar__right desktop-only">
        {% if section.settings.menu != blank %}
          <span class="inline-menu">
            {% for link in linklists[section.settings.menu].links %}
              <a class="inline-menu__link announcement-bar__link" href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          </span>
        {% endif %}

        {% if section.settings.enable_language_selector or section.settings.enable_country_selector %}
          <div class="header-localization">
            {% render 'localization-form', id: 'annbar-localization', hide_labels: true %}
          </div>
        {% endif %}
      </div>
    </div>
  </announcement-bar>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var bar = document.getElementById('section-id-{{ section.id }}');
      if (!bar) return;

      var storageKey = 'announcement-bar-dismissed-{{ section.id }}';

      try {
        if (window.localStorage && window.localStorage.getItem(storageKey) === 'true') {
          bar.style.display = 'none';
          bar.setAttribute('aria-hidden', 'true');
          return;
        }
      } catch (e) {}

      var dismissButtons = bar.querySelectorAll('[data-announcement-dismiss]');
      dismissButtons.forEach(function(btn) {
        btn.addEventListener('click', function(event) {
          event.stopPropagation();
          bar.style.display = 'none';
          bar.setAttribute('aria-hidden', 'true');
          try {
            if (window.localStorage) {
              window.localStorage.setItem(storageKey, 'true');
            }
          } catch (e) {}
        });
      });

      var toggleTargets = bar.querySelectorAll('[data-announcement-toggle]');
      toggleTargets.forEach(function(el) {
        el.addEventListener('click', function(event) {
          if (event.target.closest('a, button')) {
            return;
          }
          bar.classList.toggle('announcement-bar--expanded');
        });
      });
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "color",
      "id": "announcement_bar_col",
      "label": "Bar",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "announcement_text_col",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "message_font_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Announcement font size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Links"
    },
    {
      "type": "paragraph",
      "content": "Links, social media icons, and localization options will show in the menu on mobile"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social media links",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "info": "This menu won't show dropdown items"
    },
    {
      "type": "header",
      "content": "Country/Region Selector",
      "info": "To add a country/region, go to your [payment settings.](/admin/settings/payments)"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "label": "Enable country/region selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Language Selector",
      "info": "To add a language, go to your [language settings.](/admin/settings/languages)"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "label": "Enable language selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "Announce <a href=\"#\">something</a> here"
        },
        {
          "type": "header",
          "content": "Countdown timer"
        },
        {
          "type": "checkbox",
          "id": "show_countdown",
          "label": "Show countdown timer",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_on_end",
          "label": "Hide the announcement when the date and time elapses",
          "default": false
        },
        {
          "type": "text",
          "id": "end_date",
          "label": "End date",
          "info": "Required. Format: YYYY-MM-DD."
        },
        {
          "type": "text",
          "id": "end_time",
          "label": "End time (optional)",
          "info": "Format: 17:00 (24 hour clock). Uses the store's timezone."
        },
        {
          "type": "select",
          "id": "number_font",
          "label": "Number font",
          "options": [
            {
              "label": "Text font",
              "value": "base"
            },
            {
              "label": "Heading font",
              "value": "heading"
            }
          ],
          "default": "base"
        },
        {
          "type": "select",
          "id": "countdown_separator",
          "label": "Separation style",
          "options": [
            {
              "label": "Box",
              "value": "box"
            },
            {
              "label": "Dash",
              "value": "dash"
            },
            {
              "label": "Dot",
              "value": "dot"
            },
            {
              "label": "Space",
              "value": "space"
            }
          ],
          "default": "box"
        }
      ]
    }
  ]
}
{% endschema %}
