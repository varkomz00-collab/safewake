{% style %}
  /* ── SafeWake Apple-style collection cards ── */

  /* Section heading: tight tracking, semibold */
  .section-id-{{ section.id }} .hometitle,
  .section-id-{{ section.id }} .has-paging__title {
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  /* Card container: hairline border, rounded, smooth transitions */
  .section-id-{{ section.id }} .collection-block .block-inner {
    border-radius: 12px;
    border: var(--sw-border-hairline, 1px solid rgba(255, 255, 255, 0.08));
    overflow: hidden;
    background: var(--sw-surface-card, #15171E);
    transition: border-color 200ms ease;
  }

  /* Card hover: brighter border only — no lift, matches Lovable hover:border-foreground/30 */
  .section-id-{{ section.id }} .collection-block .block-inner:hover {
    border-color: rgba(255, 255, 255, 0.30);
  }

  /* Card image: cover, maintain aspect ratio */
  .section-id-{{ section.id }} .collection-block .image-cont {
    overflow: hidden;
    border-radius: var(--sw-radius-sm, 0.5rem) var(--sw-radius-sm, 0.5rem) 0 0;
  }

  .section-id-{{ section.id }} .collection-block .product-block__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .section-id-{{ section.id }} .collection-block:hover img {
    transform: scale(1.05);
  }

  /* Card title: uppercase, tight tracking, small bold text */
  .section-id-{{ section.id }} .collection-block .product-block__title,
  .section-id-{{ section.id }} .collection-block .text-overlay__title h2 {
    font-weight: 700;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.2;
    color: var(--sw-text-primary, #F5F5F5);
  }

  @media (min-width: 750px) {
    .section-id-{{ section.id }} .collection-block .product-block__title,
    .section-id-{{ section.id }} .collection-block .text-overlay__title h2 {
      font-size: 12px;
    }
  }

  /* Product count: muted text */
  .section-id-{{ section.id }} .collection-block .small-text,
  .section-id-{{ section.id }} .collection-block .small {
    color: var(--sw-text-muted, #9CA1AB);
    font-size: 10px;
    letter-spacing: 0.03em;
  }

  /* Card detail area padding */
  .section-id-{{ section.id }} .collection-block .product-block__detail {
    padding: 0.625rem 0.5rem;
  }

  /* Grid gap — match Lovable gap-1.5 (6px) */
  .section-id-{{ section.id }} .product-grid {
    gap: 6px;
  }

  /* Carousel: smooth scroll, snap, touch-friendly */
  .section-id-{{ section.id }} .collection-listing--carousel .slider__grid {
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
  }

  .section-id-{{ section.id }} .slider__item {
    scroll-snap-align: start;
  }

  /* ── Invert mode ── */
  .section-id-{{ section.id }}.collection-slider-row--invert {
    background: #fff !important;
    color: #000 !important;

    /* Reuse your existing var(--border-color, ...) hooks */
    --border-color: rgba(0, 0, 0, 0.16);

    /* We'll use this to swap the expander pill background */
    --ss-glass-bg: rgba(0, 0, 0, 0.03);
  }

  .section-id-{{ section.id }}.collection-slider-row--invert a,
  .section-id-{{ section.id }}.collection-slider-row--invert h1,
  .section-id-{{ section.id }}.collection-slider-row--invert h2,
  .section-id-{{ section.id }}.collection-slider-row--invert h3,
  .section-id-{{ section.id }}.collection-slider-row--invert h4,
  .section-id-{{ section.id }}.collection-slider-row--invert h5,
  .section-id-{{ section.id }}.collection-slider-row--invert h6,
  .section-id-{{ section.id }}.collection-slider-row--invert .slider-nav__btn {
    color: inherit !important;
  }

  /* Invert: card surfaces and borders swap to light mode */
  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .block-inner {
    background: #F5F5F5;
    border-color: rgba(0, 0, 0, 0.08);
  }

  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .block-inner:hover {
    border-color: rgba(0, 0, 0, 0.22);
  }

  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .product-block__title,
  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .text-overlay__title h2 {
    color: #111;
  }

  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .small-text,
  .section-id-{{ section.id }}.collection-slider-row--invert .collection-block .small {
    color: #6B7280;
  }

  .section-id-{{ section.id }} .collection-listing-expander {
    margin-top: 1.5rem;
    border-top: 1px solid var(--border-color, rgba(255, 255, 255, 0.08));
    padding-top: 0.75rem;
    text-align: center;
  }

  .section-id-{{ section.id }} .collection-listing-expander__summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    cursor: pointer;
    padding: 0.4rem 1.1rem;
    margin: 0 auto;
    border-radius: 999px;
    font-size: 0.85rem;
    text-transform: none;
    letter-spacing: 0.03em;
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.16));
    background: var(--ss-glass-bg, rgba(255, 255, 255, 0.03));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .section-id-{{ section.id }} .collection-listing-expander__summary::-webkit-details-marker {
    display: none;
  }

  .section-id-{{ section.id }} .collection-listing-expander__summary::after {
    content: "⌄";
    font-size: 0.9em;
    transform-origin: center;
    transition: transform 150ms ease;
  }

  .section-id-{{ section.id }} .collection-listing-expander[open] .collection-listing-expander__summary::after {
    transform: rotate(180deg);
  }

  .section-id-{{ section.id }} .collection-listing--stacked {
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .section-id-{{ section.id }} .collection-listing-expander[open] .collection-listing--stacked {
    opacity: 1;
    transform: translateY(0);
  }

  .section-id-{{ section.id }} .collection-slider--disabled {
    pointer-events: none;
    opacity: 0.6;
  }

  .section-id-{{ section.id }} .collection-listing-expander--desktop {
    display: none;
  }

  .section-id-{{ section.id }} .collection-listing-expander--mobile {
    display: block;
  }

  @media (min-width: 750px) {
    .section-id-{{ section.id }} .collection-listing-expander--desktop {
      display: block;
    }

    .section-id-{{ section.id }} .collection-listing-expander--mobile {
      display: none;
    }
  }

  @media (max-width: 749px) {
    .section-id-{{ section.id }} .collection-listing--stacked .product-grid {
      row-gap: 0.75rem;
    }
  }

  .section-id-{{ section.id }} .product-grid img {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    display: block;
  }

  .section-id-{{ section.id }} .product-grid > * {
    max-width: 100% !important;
  }
{% endstyle %}

<script>
document.addEventListener('DOMContentLoaded', function () {
  var root = document.querySelector('.section-id-{{ section.id }}');
  if (!root) return;

  var sliderContainer = root.querySelector('.collection-listing--carousel');
  var sliderGrid = sliderContainer ? sliderContainer.querySelector('.product-grid') : null;
  var sliderItems = sliderGrid ? Array.from(sliderGrid.querySelectorAll('.slider__item')) : [];
  var expanders = Array.from(root.querySelectorAll('.collection-listing-expander'));
  var stackedGrids = Array.from(root.querySelectorAll('.collection-listing-expander .collection-listing--stacked .product-grid'));
  var navButtons = Array.from(root.querySelectorAll('.slider-nav .slider-nav__btn'));

  // This is the visible viewport we compare against
  var viewportEl = sliderContainer;

  if (!sliderContainer || !sliderGrid || !sliderItems.length || !expanders.length) {
    return;
  }

  // Map each logical collection index -> one real DOM node
  var indexToItem = {};
  var indexSet = new Set();

  sliderItems.forEach(function (item) {
    var idxAttr = item.getAttribute('data-collection-index');
    if (idxAttr == null) return;

    var idx = parseInt(idxAttr, 10);
    if (isNaN(idx)) return;

    // First one wins for each index (clones get ignored)
    if (!Object.prototype.hasOwnProperty.call(indexToItem, idx)) {
      indexToItem[idx] = item;
    }
    indexSet.add(idx);
  });

  var allIndices = Array.from(indexSet).sort(function (a, b) { return a - b; });

  function getVisibleIndices() {
    var visibleSet = new Set();
    var viewportRect = (viewportEl || sliderGrid).getBoundingClientRect();

    sliderItems.forEach(function (item) {
      var idxAttr = item.getAttribute('data-collection-index');
      if (idxAttr == null) return;

      var idx = parseInt(idxAttr, 10);
      if (isNaN(idx)) return;

      var rect = item.getBoundingClientRect();
      // Consider item visible if at least 30% of it overlaps the viewport
      var overlap = Math.min(rect.right, viewportRect.right) - Math.max(rect.left, viewportRect.left);
      if (overlap > 0 && overlap >= rect.width * 0.3) {
        visibleSet.add(idx);
      }
    });

    // Fallback: assume first N logical items are "visible"
    if (visibleSet.size === 0) {
      var perRow = {{ section.settings.grid | default: 4 }};
      allIndices.slice(0, perRow).forEach(function (idx) {
        visibleSet.add(idx);
      });
    }

    return Array.from(visibleSet).sort(function (a, b) { return a - b; });
  }

  function computeHiddenIndices() {
    if (!allIndices.length) return [];

    var visibleIndices = getVisibleIndices();
    if (!visibleIndices.length) return [];

    var firstVisible = visibleIndices[0];
    var lastVisible = visibleIndices[visibleIndices.length - 1];

    // To the right of the current viewport
    var hiddenRight = allIndices.filter(function (idx) {
      return idx > lastVisible;
    });

    // To the left of the current viewport
    var hiddenLeft = allIndices.filter(function (idx) {
      return idx < firstVisible;
    });

    // ✅ Order: LEFT side first, then RIGHT side
    return hiddenLeft.concat(hiddenRight);
  }


  function populateStackedGrids() {
    if (!stackedGrids.length) return;

    var hiddenIndices = computeHiddenIndices();
    var html = '';

    hiddenIndices.forEach(function (idx) {
      var item = indexToItem[idx];
      if (!item) return;
      html += item.innerHTML;
    });

    stackedGrids.forEach(function (grid) {
      grid.innerHTML = html;
    });
  }

  function anyExpanderOpen() {
    return expanders.some(function (details) {
      return details.open;
    });
  }

  function updateSliderState() {
    var open = anyExpanderOpen();

    if (open) {
      sliderContainer.classList.add('collection-slider--disabled');
      navButtons.forEach(function (btn) { btn.disabled = true; });

      // Let any carousel transform/scroll settle, then read the DOM once
      setTimeout(populateStackedGrids, 60);
    } else {
      sliderContainer.classList.remove('collection-slider--disabled');
      navButtons.forEach(function (btn) { btn.disabled = false; });
    }
  }

  function refreshIfExpanded() {
    if (!anyExpanderOpen()) return;
    populateStackedGrids();
  }

  // When you open/close "Show more"
  expanders.forEach(function (details) {
    details.addEventListener('toggle', updateSliderState);
  });

  // When you click next/prev WHILE expanded, recompute after the slide moves
  navButtons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setTimeout(refreshIfExpanded, 350);
    });
  });

  // When the carousel scrolls/dragged WHILE expanded (touch/drag sliders)
  if (sliderContainer) {
    sliderContainer.addEventListener('scroll', function () {
      refreshIfExpanded();
    });
  }

  // When the viewport changes (desktop ↔ mobile, resize) WHILE expanded
  window.addEventListener('resize', function () {
    refreshIfExpanded();
  });
});
</script>
