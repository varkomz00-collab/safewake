<div class="section-id-{{ section.id }} collection-slider-row for-collections{% if section.settings.invert_bw %} collection-slider-row--invert{% endif %} {% if section.settings.color_scheme != 'default' %}use-color-scheme use-color-scheme--{{ section.settings.color_scheme }}{% endif %}">
  <div class="container{% if section.settings.enable_carousel %} container--not-mobile{% endif %}{% if section.settings.full_width %} container--no-max{% endif %}">
    {%- if section.settings.enable_carousel -%}
      <carousel-slider class="carousel block collection-slider">
    {%- endif -%}

    <h2 class="hometitle h4 align-center has-paging{% if section.settings.enable_carousel %} slider-nav{% endif %}" data-cc-animate data-cc-animate-delay="0.3s">
      {% if section.settings.enable_carousel %}
        <button name="prev" class="slider-nav__btn has-ltr-icon">
          <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
          {% render 'icon-chevron-left' %}
        </button>
      {% endif %}
      <span class="has-paging__title">{{ section.settings.title | escape }}</span>
      {% if section.settings.enable_carousel %}
        <button name="next" class="slider-nav__btn has-ltr-icon">
          <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
          {% render 'icon-chevron-right' %}
        </button>
      {% endif %}
    </h2>

    <div class="collection-listing collection-listing--carousel fade-in-up{% if section.settings.enable_carousel %} slider {% if section.settings.full_width %}slider--edge-peek{% endif %} slider--mobile-container-pad slider--no-scrollbar{% endif %}" data-cc-animate>
      <div class="product-grid product-grid--per-row-{{ section.settings.grid }} product-grid--per-row-mob-{{ section.settings.coll_thumb_mob_per_row }} product-grid--image-shape-{{ section.settings.coll_grid_image_shape }}{% if section.settings.enable_carousel %} slider__grid product-grid--carousel{% endif %}">

        {%- if section.blocks.size > 0 -%}

          {%- comment -%} Determine chosen_aspect_ratio {%- endcomment -%}
          {% if section.settings.coll_grid_image_shape == 'portrait-23' %}
            {% assign chosen_aspect_ratio = 0.67 %}
          {% elsif section.settings.coll_grid_image_shape == 'portrait-45' %}
            {% assign chosen_aspect_ratio = 0.8 %}
          {% elsif section.settings.coll_grid_image_shape == 'square' %}
            {% assign chosen_aspect_ratio = 1.0 %}
          {% elsif section.settings.coll_grid_image_shape == 'landscape-54' %}
            {% assign chosen_aspect_ratio = 1.25 %}
          {% elsif section.settings.coll_grid_image_shape == 'landscape-32' %}
            {% assign chosen_aspect_ratio = 1.50 %}
          {% elsif section.settings.coll_grid_image_shape == 'tallest' %}
            {% assign chosen_aspect_ratio = 999 %}
            {% for block in section.blocks %}
              {% assign collection_obj = collections[block.settings.collection] %}
              {% if collection_obj != blank %}
                {% assign collection_image = block.settings.image | default: collection_obj.featured_image %}
                {% if collection_image and collection_image.aspect_ratio < chosen_aspect_ratio %}
                  {% assign chosen_aspect_ratio = collection_image.aspect_ratio %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% else %}
            {% assign chosen_aspect_ratio = 0 %}
            {% for block in section.blocks %}
              {% assign collection_obj = collections[block.settings.collection] %}
              {% if collection_obj != blank %}
                {% assign collection_image = block.settings.image | default: collection_obj.featured_image %}
                {% if collection_image and collection_image.aspect_ratio > chosen_aspect_ratio %}
                  {% assign chosen_aspect_ratio = collection_image.aspect_ratio %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {%- comment -%} Render actual collection blocks {%- endcomment -%}
          {% for block in section.blocks %}
            {% assign collection = collections[block.settings.collection] %}

            {% if section.settings.enable_carousel %}
              <div class="slider__item" data-collection-index="{{ forloop.index0 }}">
            {% endif %}

            {% if collection != blank %}
              {% render 'collection-block',
                collection: collection,
                subheading: block.settings.subheading,
                button_label: block.settings.button_label,
                custom_attrs: block.shopify_attributes,
                custom_image: block.settings.image,
                custom_aspect_ratio: chosen_aspect_ratio,
                settings_object: section.settings
              %}
            {% else %}
              {% render 'onboarding-collection-block',
                forloop: forloop,
                settings_object: section.settings
              %}
            {% endif %}

            {% if section.settings.enable_carousel %}
              </div>
            {% endif %}
          {% endfor %}

        {%- else -%}

          {%- comment -%} Onboarding fallback {%- endcomment -%}
          {% for i in (1..6) %}
            {% if section.settings.enable_carousel %}
              <div class="slider__item" data-collection-index="{{ forloop.index0 }}">
            {% endif %}

            {% render 'onboarding-collection-block',
              forloop: forloop,
              settings_object: section.settings
            %}

            {% if section.settings.enable_carousel %}
              </div>
            {% endif %}
          {% endfor %}

        {%- endif -%}

      </div>
    </div>

    {%- if section.settings.enable_carousel -%}
      </carousel-slider>
    {%- endif -%}

    {%- comment -%}
      Dynamic "Show more" logic:
      - Only shows collections that are NOT currently visible in the top carousel viewport.
      - Order: first hidden to the right, then hidden to the left.
      - Recalculates when:
        * Dropdown is opened
        * Slider arrows clicked
        * Slider scrolled/dragged
        * Window resized
    {%- endcomment -%}

    {%- if section.settings.enable_carousel and section.blocks.size > 1 -%}
      {%- assign desktop_min = section.settings.grid | default: 4 | plus: 0 -%}
      {%- assign mobile_min = section.settings.coll_thumb_mob_per_row | default: 2 | plus: 0 -%}

      {%- if section.blocks.size > mobile_min -%}
        <details class="collection-listing-expander collection-listing-expander--mobile" data-cc-animate data-cc-animate-delay="0.4s">
          <summary class="collection-listing-expander__summary">
            <span class="collection-listing-expander__label">
              Show more {{ section.settings.title | escape }}
            </span>
          </summary>

          <div class="collection-listing collection-listing--stacked">
            <div
              class="product-grid product-grid--per-row-{{ section.settings.grid }} product-grid--per-row-mob-{{ section.settings.coll_thumb_mob_per_row }} product-grid--image-shape-{{ section.settings.coll_grid_image_shape }}"
              data-dynamic-grid="mobile">
              <!-- JS will inject hidden collections here -->
            </div>
          </div>
        </details>
      {%- endif -%}

      {%- if section.blocks.size > desktop_min -%}
        <details class="collection-listing-expander collection-listing-expander--desktop" data-cc-animate data-cc-animate-delay="0.4s">
          <summary class="collection-listing-expander__summary">
            <span class="collection-listing-expander__label">
              Show more {{ section.settings.title | escape }}
            </span>
          </summary>

          <div class="collection-listing collection-listing--stacked">
            <div
              class="product-grid product-grid--per-row-{{ section.settings.grid }} product-grid--per-row-mob-{{ section.settings.coll_thumb_mob_per_row }} product-grid--image-shape-{{ section.settings.coll_grid_image_shape }}"
              data-dynamic-grid="desktop">
              <!-- JS will inject hidden collections here -->
            </div>
          </div>
        </details>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>


