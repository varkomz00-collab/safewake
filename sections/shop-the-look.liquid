<link rel="stylesheet" href="{{ 'shop-the-look.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>
{%- if section.blocks.size > 1 -%}
  <script src="{{ 'slideshow.js' | asset_url }}" defer></script>
{%- endif -%}
{%- if section.settings.video_shopify != blank or section.settings.video_external != blank -%}
  <link rel="stylesheet" href="{{ 'video.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>
  <script src="{{ 'video.js' | asset_url }}" defer></script>
{%- endif -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'countdown' -%}
    <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
  {%- endif -%}
{%- endfor -%}

{%- liquid
  if section.settings.image
    assign main_image = section.settings.image
  elsif section.settings.video_shopify
    assign main_image = section.settings.video_shopify.preview_image
  endif

  assign show_text_content = false
  if section.blocks != empty
    assign show_text_content = true
  endif

  if section.settings.show_swatches
    assign hide_swatches = false
  else
    assign hide_swatches = true
  endif

  if section.settings.product_list != blank
    if settings.prod_thumb_shape == 'portrait-23'
      assign chosen_aspect_ratio = 0.67
    elsif settings.prod_thumb_shape == 'portrait-45'
      assign chosen_aspect_ratio = 0.8
    elsif settings.prod_thumb_shape == 'square'
      assign chosen_aspect_ratio = 1.0
    elsif settings.prod_thumb_shape == 'landscape-54'
      assign chosen_aspect_ratio = 1.25
    elsif settings.prod_thumb_shape == 'landscape-32'
      assign chosen_aspect_ratio = 1.50
    elsif settings.prod_thumb_shape == 'tallest'
      assign chosen_aspect_ratio = 99
      for product in section.settings.product_list
        if product.featured_media.preview_image.aspect_ratio < chosen_aspect_ratio
          assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
        endif
      endfor
    else
      assign chosen_aspect_ratio = 0
      for product in section.settings.product_list
        if product.featured_media.preview_image.aspect_ratio > chosen_aspect_ratio
          assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
        endif
      endfor
    endif
  endif

  assign products_alignment_y = section.settings.products_alignment | split: ' ' | first
  assign has_text_block = false
  assign has_countdown_block = false
  assign total_button_count = 0
  assign primary_button_id = ''

  for block in section.blocks
    if block.type == 'text'
      assign has_text_block = true
    endif
    if block.type == 'countdown'
      assign has_countdown_block = true
    endif
    if block.type == 'button'
      assign total_button_count = total_button_count | plus: 1
      if primary_button_id == ''
        assign primary_button_id = block.id
      endif
    endif
  endfor
-%}

<image-with-text-overlay
  id="section-id-{{ section.id }}"
  class="{% if section.settings.video_shopify != blank or section.settings.video_external != blank %}video-section video-section--background{% endif %}"
>
  {% style %}
    {%- if section.settings.height == 'fixed' %}
      #section-id-{{ section.id }} .height--fixed {
        --image-height: {{ section.settings.height_mobile }}px;
      }

      @media (min-width: 768px) {
        #section-id-{{ section.id }} .height--fixed {
          --image-height: {{ section.settings.height_desktop }}px;
        }
      }
    {%- elsif section.settings.height == 'adapt' -%}
      #section-id-{{ section.id }} .height--adapt {
        {%- if section.settings.mobile_image -%}
          --aspect-ratio: {{ section.settings.mobile_image.aspect_ratio }};
        {%- else -%}
          --aspect-ratio: {{ main_image.aspect_ratio | default: 2.0 }};
        {%- endif -%}
      }

      {%- if section.settings.mobile_image -%}
        @media (min-width: 768px) {
          #section-id-{{ section.id }} .height--adapt {
            --aspect-ratio: {{ main_image.aspect_ratio | default: 2.0 }};
          }
        }
      {%- endif -%}
    {%- endif -%}

    {%- for block in section.blocks -%}
      {% if block.type == 'heading' %}
        #section-id-{{ section.id }} .block-{{ block.id }} {
          --heading-max-width: {{ block.settings.heading_max_width }}em;
          font-size: {{ block.settings.title_size_mobile }}px;
          {%- if block.settings.title_size_mobile >= 90 -%}
            line-height: 1em;
          {%- endif %}
        }

        @media (min-width: 768px) {
          #section-id-{{ section.id }} .block-{{ block.id }} {
            {%- assign title_size_medium = block.settings.title_size | times: 0.7 | at_least: block.settings.title_size_mobile -%}
            font-size: {{ title_size_medium }}px;
            {%- if title_size_medium >= 90 -%}
              line-height: 1em;
            {%- endif %}
          }
        }

        @media (min-width: 1100px) {
          #section-id-{{ section.id }} .block-{{ block.id }} {
            font-size: {{ block.settings.title_size }}px;
            {%- if block.settings.title_size >= 90 -%}
              line-height: 1em;
            {%- endif %}
          }
        }
      {% endif %}

      {% if block.type == 'countdown' %}
        .block-id-{{ block.id }} .countdown {
          --countdown-desktop-size: {{ block.settings.number_size }}px;
        }
      {% endif %}
    {%- endfor -%}

    /* Apple-style video container */
    #section-id-{{ section.id }} .video-hero__shell {
      position: relative;
    }

    #section-id-{{ section.id }} .height--fixed,
    #section-id-{{ section.id }} .height--adapt {
      border-radius: var(--sw-radius-lg, 1rem);
      overflow: hidden;
    }

    /* Bottom-only gradient overlay */
    #section-id-{{ section.id }} .image-overlay::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.5) 40%, transparent 100%);
      pointer-events: none;
      z-index: 1;
    }

    #section-id-{{ section.id }} .image-overlay__over {
      z-index: 2;
    }

    /* Content overlay positioned at bottom */
    #section-id-{{ section.id }} .video-hero__overlay-inner {
      max-width: 420px;
      padding: var(--sw-space-4, 16px);
      border-radius: 18px;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
    }

    /* Eyebrow text - Apple style */
    #section-id-{{ section.id }} .video-hero__eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 6px;
      opacity: 1;
    }

    #section-id-{{ section.id }} .video-hero__title {
      margin: 0;
      font-size: 18px;
      letter-spacing: -0.025em;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .video-hero__title {
        font-size: 30px;
      }
    }

    #section-id-{{ section.id }} .video-hero__primary-action {
      margin-top: 10px;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    #section-id-{{ section.id }} .video-hero__primary-btn {
      border-radius: 999px;
      padding-inline: 18px;
      padding-block: 8px;
      font-size: 13px;
      line-height: 1.3;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      transition: var(--sw-transition-smooth, transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease);
    }

    #section-id-{{ section.id }} .video-hero__primary-btn:hover {
      transform: translateY(-1px);
      box-shadow: var(--sw-shadow-hover, 0 12px 30px rgba(0, 0, 0, 0.4));
    }

    #section-id-{{ section.id }} .video-hero__primary-meta {
      font-size: 11px;
      opacity: 0.8;
    }

    /* Drawers / lower panel */
    #section-id-{{ section.id }} .video-hero__drawers {
      margin-top: 16px;
    }

    #section-id-{{ section.id }} .video-hero__drawers-inner {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    #section-id-{{ section.id }} .video-hero__drawer {
      border-radius: var(--sw-radius-lg, 1rem);
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(10, 10, 10, 0.85);
      padding: 0;
      overflow: hidden;
      transition: background 0.3s var(--sw-ease-smooth, ease);
    }

    /* STATIC "Shop the look" row */
    #section-id-{{ section.id }} .video-hero__drawer--static {
      background: transparent;
      border: none;
    }

    #section-id-{{ section.id }} .video-hero__drawer--static .video-hero__drawer-summary,
    #section-id-{{ section.id }} .video-hero__drawer--static .video-hero__drawer-body {
      background: transparent;
      border: none;
      padding-left: 0;
      padding-right: 0;
    }

    /* Dark card for open accordions */
    #section-id-{{ section.id }} .video-hero__drawer[open]:not(.video-hero__drawer--static) {
      background: rgba(15, 15, 15, 0.94);
    }

    #section-id-{{ section.id }} .video-hero__drawer-summary {
      list-style: none;
      cursor: default;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 14px;
    }

    #section-id-{{ section.id }} details.video-hero__drawer > .video-hero__drawer-summary {
      cursor: pointer;
    }

    #section-id-{{ section.id }} .video-hero__drawer-summary::-webkit-details-marker {
      display: none;
    }

    #section-id-{{ section.id }} .video-hero__drawer-label {
      font-size: 13px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    #section-id-{{ section.id }} .video-hero__drawer-meta {
      font-size: 11px;
      opacity: 0.75;
      margin-left: auto;
      margin-right: 8px;
    }

    #section-id-{{ section.id }} .video-hero__drawer-chevron {
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s var(--sw-ease-smooth, ease);
    }

    #section-id-{{ section.id }} .video-hero__drawer[open] .video-hero__drawer-chevron {
      transform: rotate(180deg);
    }

    #section-id-{{ section.id }} .video-hero__drawer-body {
      padding: 0 14px 12px 14px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    #section-id-{{ section.id }} .video-hero__body-text {
      margin-top: 10px;
    }

    #section-id-{{ section.id }} .video-hero__secondary-actions {
      margin-top: 10px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    /* Product list scroll area */
    #section-id-{{ section.id }} .video-hero__drawer-body--products {
      padding-top: 8px;
    }

    #section-id-{{ section.id }} .video-hero__drawer-body--products .slider {
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    #section-id-{{ section.id }} .video-hero__drawer-body--products .slider::-webkit-scrollbar {
      display: none;
    }

    #section-id-{{ section.id }} .video-hero__drawer-body--products .product-grid {
      gap: var(--sw-space-4, 16px);
    }

    #section-id-{{ section.id }} .video-hero__countdown {
      margin-top: 10px;
    }

    /* Quick board-type chips */
    #section-id-{{ section.id }} .shop-look__chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 10px;
    }

    #section-id-{{ section.id }} .shop-look__chip-btn {
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 12px;
      line-height: 1.3;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.04);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: var(--sw-transition-smooth, background 0.3s ease, border-color 0.3s ease);
    }

    #section-id-{{ section.id }} .shop-look__chip-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.3);
    }

    #section-id-{{ section.id }} .shop-look__chip-btn--primary {
      background: #ffffff;
      color: #000000;
      border-color: rgba(255, 255, 255, 0.9);
    }

    #section-id-{{ section.id }} .shop-look__chip-btn--primary:hover {
      background: rgba(255, 255, 255, 0.9);
    }

    #section-id-{{ section.id }} .shop-look__chip-btn--link {
      background: transparent;
      border-style: dashed;
      opacity: 0.85;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .video-hero__drawers {
        margin-top: 18px;
      }

      #section-id-{{ section.id }} .video-hero__overlay-inner {
        padding: var(--sw-space-8, 32px);
      }
    }

    @media (max-width: 767.98px) {
      #section-id-{{ section.id }} .video-hero__overlay-card {
        margin-bottom: 10px;
      }

      #section-id-{{ section.id }} .video-hero__overlay-inner {
        max-width: none;
      }

      #section-id-{{ section.id }} .shop-look__chips {
        overflow-x: auto;
        white-space: nowrap;
        padding-bottom: 4px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }

      #section-id-{{ section.id }} .shop-look__chips::-webkit-scrollbar {
        display: none;
      }

      #section-id-{{ section.id }} .shop-look__chip-btn {
        white-space: nowrap;
      }
    }
  {% endstyle %}

  <div class="{%- if section.settings.full_width and section.settings.mobile_overlay_over %} mobile-container {%- elsif section.settings.full_width == false -%} container fully-spaced-row--medium fully-spaced-row--not-mobile {%- if section.settings.mobile_overlay_over == false %} container--not-mobile{% endif -%}{%- endif %}">

    {%- if section.settings.mobile_overlay_over and show_text_content -%}
      <div class="video-hero__overlay-card mobile-only spaced-row-above">
        <div class="video-hero__overlay-inner">
          {%- comment -%} Subheading (first only) {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'subheading' -%}
              <div class="video-hero__eyebrow subheading" {{ block.shopify_attributes }}>
                {{ block.settings.subheading | escape }}
              </div>
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Heading (first only) {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'heading' -%}
              {%- if block.settings.use_h1 -%}
                <h1 class="video-hero__title text-overlay__title block-{{ block.id }}" {{ block.shopify_attributes }}>
                  {% render 'multiline-text' with block.settings.title %}
                </h1>
              {%- else -%}
                <h2 class="video-hero__title text-overlay__title h1 block-{{ block.id }}" {{ block.shopify_attributes }}>
                  {% render 'multiline-text' with block.settings.title %}
                </h2>
              {%- endif -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          <div class="video-hero__primary-action">
            {%- assign primary_button_rendered = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'button' and primary_button_rendered == false -%}
                <a class="video-hero__primary-btn btn btn--{{ block.settings.button_style | default: 'primary' }}" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }}>
                  {{ block.settings.button_label | escape }}
                </a>
                {%- assign primary_button_rendered = true -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    <div class="video-hero__shell">
      <div
        class="height--{{ section.settings.height }} image-overlay image-overlay--bg-{{ section.settings.overlay_style }}{% if section.settings.mobile_overlay_over and show_text_content %} image-overlay--bg-desktop-only{% endif %}"
        data-cc-animate
      >
        {%- if section.settings.image == blank and section.settings.video_shopify == blank and section.settings.video_external == blank -%}
          <div class="height__image image-overlay__image">
            <div class="placeholder-image{% if show_text_content %} dark{% endif %}">
              {{- 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' -}}
            </div>
          </div>
        {%- else -%}
          <div class="height__image image-overlay__image">
            {%- if section.settings.video_shopify != blank or section.settings.video_external != blank -%}
              <div class="{% unless section.settings.video_shopify %}video-section__bg-iframe-video{% endunless %}">
                <deferred-media>
                  <template>
                    <video-component
                      class="{% if section.settings.video_shopify %}has-video{% else %}has-iframe{% endif %}"
                      {%- unless section.settings.video_shopify %} data-video-url="{{ section.settings.video_external | escape }}"{% endunless %}
                      data-video-id="{{ section.id }}"
                      data-autoplay="true"
                      data-background="true"
                      data-description="{{ section.settings.video_description | escape }}"
                    >
                      {%- if section.settings.video_shopify -%}
                        {{ section.settings.video_shopify | video_tag: playsinline: true, autoplay: true, muted: true, loop: true, poster: '' | replace: '<img ', '<img loading="lazy" hidden ' }}
                      {%- else -%}
                        <div></div>
                      {%- endif -%}
                    </video-component>
                  </template>
                </deferred-media>
              </div>
              <div class="video-played-hidden">
            {%- endif -%}

            {%- if main_image -%}
              {%- render 'image-desktop-and-mobile', desktop_image: main_image, mobile_image: section.settings.mobile_image -%}
            {%- endif -%}

            {%- if section.settings.video_shopify != blank or section.settings.video_external != blank -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if show_text_content -%}
          <div
            class="video-hero__overlay text-overlay text-overlay--for-banner text-overlay--v-{{ section.settings.text_alignment | split: ' ' | first }} text-overlay--h-{{ section.settings.text_alignment | split: ' ' | last }} image-overlay__over{% if section.settings.mobile_overlay_over %} desktop-only{% endif %}"
          >
            <div class="text-overlay__inner video-hero__overlay-inner">
              {%- comment -%} Subheading (first only) {%- endcomment -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'subheading' -%}
                  <div class="video-hero__eyebrow subheading" {{ block.shopify_attributes }}>
                    {{ block.settings.subheading | escape }}
                  </div>
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} Heading (first only) {%- endcomment -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'heading' -%}
                  {%- if block.settings.use_h1 -%}
                    <h1 class="video-hero__title text-overlay__title block-{{ block.id }}" {{ block.shopify_attributes }}>
                      {% render 'multiline-text' with block.settings.title %}
                    </h1>
                  {%- else -%}
                    <h2 class="video-hero__title text-overlay__title h1 block-{{ block.id }}" {{ block.shopify_attributes }}>
                      {% render 'multiline-text' with block.settings.title %}
                    </h2>
                  {%- endif -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              <div class="video-hero__primary-action">
                {%- assign primary_button_rendered = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'button' and primary_button_rendered == false -%}
                    <a class="video-hero__primary-btn btn btn--{{ block.settings.button_style | default: 'primary' }}" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }}>
                      {{ block.settings.button_label | escape }}
                    </a>
                    {%- assign primary_button_rendered = true -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- if show_text_content or section.settings.product_list != blank or has_countdown_block -%}
        <div class="video-hero__drawers lightish-spaced-row-above">
          <div class="video-hero__drawers-inner">

            {%- if has_text_block or total_button_count > 1 -%}
              <details class="video-hero__drawer" open>
                <summary class="video-hero__drawer-summary">
                  <span class="video-hero__drawer-label">
                    Overview
                  </span>
                  <span class="video-hero__drawer-meta">
                    {% if has_text_block %}Quick summary{% endif %}
                  </span>
                  <span class="video-hero__drawer-chevron">
                    {% render 'icon-chevron-down' %}
                  </span>
                </summary>
                <div class="video-hero__drawer-body">
                  {%- if has_text_block -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'text' -%}
                        <div class="video-hero__body-text rte {% if block.settings.enlarge_text %}large-text{% endif %}" {{ block.shopify_attributes }}>
                          {{ block.settings.text }}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}

                  {%- if total_button_count > 1 -%}
                    <div class="video-hero__secondary-actions button-row">
                      {%- for block in section.blocks -%}
                        {%- if block.type == 'button' and block.id != primary_button_id -%}
                          <a
                            class="button-row__btn {% if block.settings.button_style != 'link' %}btn btn--{{ block.settings.button_style }}{% else %}small-feature-link{% endif %}"
                            href="{{ block.settings.button_link }}"
                            {{ block.shopify_attributes }}
                          >
                            {{ block.settings.button_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              </details>
            {%- endif -%}

            {%- if section.settings.product_list != blank -%}
              <div class="video-hero__drawer video-hero__drawer--static">
                <div class="video-hero__drawer-summary">
                  <span class="video-hero__drawer-label">
                    Shop the look
                  </span>
                  <span class="video-hero__drawer-meta">
                    {{ section.settings.product_list.count }}
                    {% if section.settings.product_list.count == 1 %}item{% else %}items{% endif %}
                  </span>
                </div>
                <div class="video-hero__drawer-body video-hero__drawer-body--products">
                  {%- if total_button_count > 0 -%}
                    <div class="shop-look__chips" aria-label="Shop by setup type">
                      {%- for block in section.blocks -%}
                        {%- if block.type == 'button' -%}
                          <a
                            class="shop-look__chip-btn {% if block.id == primary_button_id %}shop-look__chip-btn--primary{% endif %}{% if block.settings.button_style == 'link' %} shop-look__chip-btn--link{% endif %}"
                            href="{{ block.settings.button_link | default: '#' }}"
                            {{ block.shopify_attributes }}
                          >
                            {{ block.settings.button_label | escape }}
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  <carousel-slider class="carousel block">
                    <div class="slider slider--no-scrollbar slider--mobile-container-pad">
                      <ul class="slider__grid product-grid product-grid--carousel product-grid--per-row-4">
                        {%- for product in section.settings.product_list -%}
                          <li class="slider__item">
                            {% render 'product-block',
                              product: product,
                              custom_aspect_ratio: chosen_aspect_ratio,
                              compact: true,
                              card_layout: section.settings.product_card_layout,
                              hide_swatches: hide_swatches,
                              grid: 6
                            %}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  </carousel-slider>
                </div>
              </div>
            {%- endif -%}

            {%- if has_countdown_block -%}
              <details class="video-hero__drawer">
                <summary class="video-hero__drawer-summary">
                  <span class="video-hero__drawer-label">
                    Drop countdown
                  </span>
                  <span class="video-hero__drawer-meta">
                    Live timer
                  </span>
                  <span class="video-hero__drawer-chevron">
                    {% render 'icon-chevron-down' %}
                  </span>
                </summary>
                <div class="video-hero__drawer-body">
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'countdown' -%}
                      <div
                        class="video-hero__countdown block-id-{{ block.id }} countdown-font-{{ block.settings.number_font }} countdown-divider-{{ block.settings.divider_type }}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'countdown-timer',
                          end_date: block.settings.end_date,
                          end_time: block.settings.end_time,
                          end_text: block.settings.end_text,
                          end_midnight: true,
                          hide_on_end: block.settings.hide_on_end,
                          show_labels: block.settings.show_timer_labels
                        %}
                      </div>
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </details>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</image-with-text-overlay>

