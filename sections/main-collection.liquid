<div data-section-id="{{ section.id }}" data-cc-animate>

{% style %}
  /* ============================================================
     SAFEWAKE COLLECTION PAGE — Apple-style design refinements
     Uses design tokens from safewake-design-tokens.css
     ============================================================ */

  /* -----------------------------------------------------------
     1. RELATED COLLECTIONS COMPACT CAROUSEL
     ----------------------------------------------------------- */
  .collections-widget {
    width: 100%;
    background: rgba(var(--sw-glow-h, 205), 10%, 10%, 0.8);
    background: var(--sw-surface-section, #101218);
    padding: 0.75rem 0 1rem;
    color: var(--sw-text-primary, #F5F5F5);
    position: sticky;
    top: 60px;
    z-index: 20;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    background-color: rgba(16, 18, 24, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .collections-widget .collections-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 0.75rem;
  }

  .collections-widget .collections-carousel .slider {
    overflow-x: auto;
    overflow-y: hidden;
    width: 100%;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    touch-action: pan-x;
  }

  .collections-widget .collections-carousel .slider::-webkit-scrollbar {
    display: none;
  }
  .collections-widget .collections-carousel .slider {
    scrollbar-width: none;
  }

  .collections-widget .collections-carousel .slider__grid {
    display: flex;
    gap: 0;
    margin-left: -0.25rem;
  }

  .collections-widget .collection-item {
    flex: 0 0 24%;
    min-width: 0;
    padding-left: 0.25rem;
  }

  .collections-widget .collection-link {
    display: block;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--sw-radius-sm, 0.5rem);
    background: var(--sw-surface-card, #15171E);
    border: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
    transition: border-color 0.2s ease, filter 0.2s ease;
    text-decoration: none;
  }

  .collections-widget .collection-link:hover {
    filter: brightness(1.12);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .collections-widget .collection-link--active {
    border-color: hsl(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%));
    box-shadow: 0 0 0 2px hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.55);
  }

  .collections-widget .collection-link--active .collection-primary {
    color: hsl(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%));
  }

  .collections-widget .collection-link--active .collection-secondary {
    color: var(--sw-text-primary, #F5F5F5);
  }

  .collections-widget .collection-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    transition: transform 0.4s var(--sw-ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .collections-widget .collection-link:hover .collection-image {
    transform: scale(1.04);
  }

  .collections-widget .collection-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.05) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .collections-widget .collection-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    text-align: center;
    z-index: 2;
  }

  .collections-widget .collection-primary {
    color: var(--sw-text-primary, #F5F5F5);
    font-weight: 900;
    font-size: 0.5625rem;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 0.125rem;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.3s var(--sw-ease-smooth, ease);
  }

  .collections-widget .collection-secondary {
    color: var(--sw-text-muted, #9CA1AB);
    font-weight: 500;
    font-size: 0.4375rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.3s var(--sw-ease-smooth, ease);
  }

  .collections-widget .slider-nav__btn {
    width: var(--sw-touch-target, 44px);
    height: var(--sw-touch-target, 44px);
    border-radius: var(--sw-radius-pill, 999px);
    background: var(--sw-surface-card, #15171E);
    border: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: var(--sw-shadow-soft, 0 2px 8px rgba(0,0,0,0.2));
  }

  .collections-widget .slider-nav__btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .collections-widget .slider-nav__btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.08);
    box-shadow: var(--sw-shadow-medium, 0 4px 16px rgba(0,0,0,0.3));
  }

  .collections-widget .slider-nav__btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  @media (min-width: 640px) {
    .collections-widget .collection-item {
      flex: 0 0 20%;
    }
    .collections-widget .collection-primary {
      font-size: 0.875rem;
    }
    .collections-widget .collection-secondary {
      font-size: 0.625rem;
    }
  }

  @media (min-width: 960px) {
    .collections-widget .collection-item {
      flex: 0 0 12.5%;
    }
    .collections-widget .collection-primary {
      font-size: 0.95rem;
    }
    .collections-widget .collection-secondary {
      font-size: 0.7rem;
    }
  }

  @media (min-width: 1280px) {
    .collections-widget .collection-item {
      flex: 0 0 10%;
    }
  }

  /* -----------------------------------------------------------
     7. COLLECTION HEADER — tight letter-spacing, muted desc
     ----------------------------------------------------------- */
  .page-header h1,
  .page-header .collection-title {
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--sw-text-primary, #F5F5F5);
  }

  .page-header .rte,
  .page-header .text-overlay__rte {
    color: var(--sw-text-muted, #9CA1AB);
  }

  /* -----------------------------------------------------------
     2. FILTER SIDEBAR / STRIP
     ----------------------------------------------------------- */
  .filter-container {
    transition: opacity 0.3s ease;
  }

  /* Toggle button — match Lovable rounded-full p-2 hover:bg-muted */
  .toggle-btn[data-toggle-filters] {
    min-height: var(--sw-touch-target, 44px);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .toggle-btn[data-toggle-filters]:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .toggle-btn__chevron {
    transition: transform 0.3s var(--sw-ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .toggle-btn--revealed-desktop .toggle-btn__chevron,
  .filter-container--show-filters-desktop .toggle-btn__chevron {
    transform: rotate(90deg);
  }

  /* Hairline dividers between filter groups */
  .cc-accordion .cc-accordion__panel + .cc-accordion__panel,
  .filter-group + .filter-group,
  .faceted-filters__group + .faceted-filters__group {
    border-top: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
  }

  /* Smooth expand/collapse for filter panels */
  .cc-accordion__body,
  .faceted-filters__body {
    transition: max-height 0.35s var(--sw-ease-smooth, cubic-bezier(0.4, 0, 0.2, 1)),
                opacity 0.25s ease;
    overflow: hidden;
  }

  /* Filter group headings */
  .cc-accordion__heading button,
  .faceted-filters__heading button {
    min-height: var(--sw-touch-target, 44px);
    font-weight: 500;
    color: var(--sw-text-secondary, #CDD0D6);
    letter-spacing: -0.01em;
  }

  /* -----------------------------------------------------------
     5. ACTIVE FILTER TAGS — pill-shaped
     ----------------------------------------------------------- */
  .active-filters__tag,
  .tag-list__tag--active,
  .faceted-filters__active-tag,
  .toggle-btn__count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--sw-surface-card, #15171E);
    border: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
    border-radius: var(--sw-radius-pill, 999px);
    padding: 0.375rem 0.75rem;
    min-height: 40px;
    font-size: 0.75rem;
    color: var(--sw-text-secondary, #CDD0D6);
    line-height: 1.4;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .active-filters__tag:hover,
  .faceted-filters__active-tag:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .active-filters__tag .active-filters__remove,
  .faceted-filters__active-tag .remove-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: var(--sw-radius-pill, 999px);
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .active-filters__tag:hover .active-filters__remove,
  .faceted-filters__active-tag:hover .remove-tag {
    opacity: 1;
  }

  /* -----------------------------------------------------------
     3. SORT DROPDOWN — clean styling
     ----------------------------------------------------------- */
  .link-dropdown__button {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    min-height: var(--sw-touch-target, 44px);
    padding: 0.5rem 0.75rem;
    color: var(--sw-text-secondary, #CDD0D6);
    font-size: 0.875rem;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .link-dropdown__button-icon {
    transition: transform 0.3s var(--sw-ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .link-dropdown__button[aria-expanded="true"] .link-dropdown__button-icon {
    transform: rotate(180deg);
  }

  .link-dropdown__options {
    position: absolute;
    right: 0;
    top: 100%;
    z-index: 100;
    min-width: 12rem;
    background: var(--sw-surface-card, #15171E);
    border: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
    border-radius: var(--sw-radius-md, 0.75rem);
    box-shadow: var(--sw-shadow-medium, 0 4px 16px rgba(0,0,0,0.3));
    padding: 0.375rem;
    overflow: hidden;
  }

  .link-dropdown__link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--sw-radius-sm, 0.5rem);
    color: var(--sw-text-secondary, #CDD0D6);
    font-size: 0.875rem;
    transition: background 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .link-dropdown__link:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--sw-text-primary, #F5F5F5);
  }

  .link-dropdown__link--active {
    color: var(--sw-text-primary, #F5F5F5);
    font-weight: 600;
    background: rgba(43, 173, 212, 0.1);
  }

  /* Mobile sort — bottom-sheet feel (Lovable Sheet: rounded-t-2xl bg-card) */
  @media (max-width: 639px) {
    .link-dropdown__options {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      top: auto;
      border-radius: 16px 16px 0 0;
      padding: 0.5rem 0.5rem 1.5rem;
      padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
      max-height: 60vh;
      overflow-y: auto;
      background: var(--sw-surface-card, #15171E);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.5);
      -webkit-backdrop-filter: blur(16px);
      backdrop-filter: blur(16px);
    }

    .link-dropdown__link {
      min-height: var(--sw-touch-target, 44px);
      display: flex;
      align-items: center;
      font-size: 1rem;
    }
  }

  /* -----------------------------------------------------------
     4. PRODUCT GRID — consistent spacing
     ----------------------------------------------------------- */
  /* Grid gap: Lovable gap-2 sm:gap-3 = 8px / 12px */
  .product-grid {
    gap: 8px;
    grid-template-columns: repeat(2, 1fr);
  }

  .collection-listing .product-grid {
    row-gap: 8px;
    column-gap: 8px;
  }

  @media (min-width: 640px) {
    .product-grid,
    .collection-listing .product-grid {
      gap: 12px;
      row-gap: 12px;
      column-gap: 12px;
    }
  }

  /* 3-col intermediate step — match Lovable 2→3→4 responsive grid */
  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 960px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* -----------------------------------------------------------
     6. PAGINATION — clean, 44px touch targets, brand glow
     ----------------------------------------------------------- */
  .pagination-row {
    padding: 2rem 0;
  }

  .pagination__item,
  .pagination a,
  .pagination span,
  .pagination-control a,
  .pagination-control span.current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--sw-touch-target, 44px);
    min-height: var(--sw-touch-target, 44px);
    padding: 0 0.5rem;
    border-radius: var(--sw-radius-sm, 0.5rem);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sw-text-secondary, #CDD0D6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .pagination a:hover,
  .pagination-control a:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--sw-text-primary, #F5F5F5);
  }

  .pagination .current,
  .pagination span[aria-current="page"],
  .pagination-control span.current {
    background: hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.15);
    color: hsl(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%));
    font-weight: 600;
    box-shadow: 0 0 12px hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.2);
    border: 1px solid hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.3);
  }

  .pagination .prev,
  .pagination .next,
  .pagination-control .prev,
  .pagination-control .next {
    min-width: var(--sw-touch-target, 44px);
    min-height: var(--sw-touch-target, 44px);
  }

  /* -----------------------------------------------------------
     8. EMPTY STATE — centered, clean typography
     ----------------------------------------------------------- */
  .collection-listing h5.align-centre,
  .collection-listing .align-centre {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    color: var(--sw-text-muted, #9CA1AB);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    text-align: center;
  }

  /* -----------------------------------------------------------
     UTILITY BAR refinements
     ----------------------------------------------------------- */
  .utility-bar {
    border-bottom: var(--sw-border-hairline, 1px solid rgba(255,255,255,0.06));
    padding-bottom: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .utility-bar__item {
    color: var(--sw-text-secondary, #CDD0D6);
    font-size: 0.875rem;
  }

  /* Layout switcher icons */
  .layout-switch {
    min-width: var(--sw-touch-target, 44px);
    min-height: var(--sw-touch-target, 44px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--sw-radius-sm, 0.5rem);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .layout-switch:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .layout-switch--active {
    color: var(--sw-text-primary, #F5F5F5);
  }

  /* -----------------------------------------------------------
     DESCRIPTION below products
     ----------------------------------------------------------- */
  .container--reading-width .rte {
    color: var(--sw-text-muted, #9CA1AB);
    line-height: 1.7;
  }
{% endstyle %}

{% paginate collection.products by section.settings.coll_num_per_page_int %}

{%- liquid
  if section.settings.show_image_behind_heading and collection.image
    assign header_image_enabled = true
  else
    assign header_image_enabled = false
  endif
  assign current_sort = collection.sort_by | default: collection.default_sort_by

  assign show_filters = section.settings.enable_filtering
  if collection.filters == empty
    assign show_filters = false
  endif
-%}

{%- liquid
  assign related_collections_count = 0
  if section.settings.related_collections != empty
    for loop_collection in section.settings.related_collections
      assign related_collections_count = related_collections_count | plus: 1
    endfor
  endif
-%}

{%- if related_collections_count > 0 -%}
  {% capture related_collection_html %}
    {% if section.settings.related_collections_style == 'buttons' %}
      <div class="container{% if header_image_enabled %} container--not-mobile{% endif %} lightish-spaced-row-above">
        <related-collection-link-buttons class="related-collection-links related-collection-links--buttons align-center{% if header_image_enabled %} image-overlay__over{% endif %}" data-expander-btn-text="{{ 'sections.collection.view_all_related_collections' | t }}">
          {%- for loop_collection in section.settings.related_collections -%}
            {%- liquid
              assign is_active_collection = false
              if loop_collection.handle == collection.handle
                assign is_active_collection = true
              endif
            -%}
            <a
              class="btn btn--tertiary{% if is_active_collection %} btn--primary{% endif %}"
              {% if is_active_collection %}aria-current="page"{% endif %}
              href="{{ loop_collection.url }}"
            >
              {{ loop_collection.title | escape }}
            </a>
          {%- endfor -%}
        </related-collection-link-buttons>
      </div>
    {% else %}
      {% unless section.settings.rel_coll_gall_full_width %}
        <div class="container container--not-mobile{% if section.settings.rel_coll_grid_mobile == 'hide' %} desktop-only{% endif %}">
      {% endunless %}

      <div class="
        related-collection-links
        related-collection-links--gallery
        {%- if section.settings.rel_coll_gall_full_width %} related-collection-links--is-full-width{% endif %}
        {%- if header_image_enabled %} related-collection-links--under-image-header{% endif %}
        {%- if section.settings.rel_coll_grid_mobile == 'hide' %} desktop-only{% endif %}">

        <div class="collections-widget">
          <div class="collections-container">
            <!-- Carousel (reuses existing Symmetry slider markup, now native-scroll) -->
            <carousel-slider class="carousel collections-carousel{% if section.settings.rel_coll_grid_mobile == 'hide' %} desktop-only{% endif %}" inactive>
              <div class="slider slider--no-scrollbar" id="slider-{{ section.id }}">
                <div class="slider__grid">
                  {%- for loop_collection in section.settings.related_collections -%}
                    {%- liquid
                      assign is_active_collection = false
                      if loop_collection.handle == collection.handle
                        assign is_active_collection = true
                      endif
                    -%}
                    <div class="slider__item collection-item">
                      <a class="collection-link{% if is_active_collection %} collection-link--active{% endif %}" href="{{ loop_collection.url }}">
                        {%- if loop_collection.image != blank -%}
                          <img
                            src="{{ loop_collection.image | image_url: width: 800 }}"
                            alt="{{ loop_collection.title | escape }}"
                            class="collection-image"
                            loading="lazy"
                          />
                          <div class="collection-overlay"></div>
                        {%- endif -%}

                        <div class="collection-content">
                          {%- liquid
                            assign primary = ''
                            assign secondary = ''

                            # 1) Metafield overrides (admin editable for labels)
                            if loop_collection.metafields.custom.collection_primary_label != blank
                              assign primary = loop_collection.metafields.custom.collection_primary_label | upcase
                            elsif loop_collection.metafields.custom.primary_label != blank
                              assign primary = loop_collection.metafields.custom.primary_label | upcase
                            endif

                            if loop_collection.metafields.custom.collection_secondary_label != blank
                              assign secondary = loop_collection.metafields.custom.collection_secondary_label | upcase
                            elsif loop_collection.metafields.custom.secondary_label != blank
                              assign secondary = loop_collection.metafields.custom.secondary_label | upcase
                            endif

                            # 2) Hard-coded mapping (only if no metafields)
                            if primary == '' and secondary == ''
                              case loop_collection.handle
                                when 'boat-wakeboard'
                                  assign primary = 'WAKEBOARD'
                                  assign secondary = 'BOAT'
                                when 'cable-wakeboard'
                                  assign primary = 'WAKEBOARD'
                                  assign secondary = 'CABLE'
                                when 'bindings'
                                  assign primary = 'BINDINGS'
                                  assign secondary = 'STANDARD'
                                when 'system-bindings'
                                  assign primary = 'BINDINGS'
                                  assign secondary = 'SYSTEM'
                                when 'gloves'
                                  assign primary = 'GLOVES'
                                  assign secondary = 'WATERSPORT'
                                when 'ncga-vest'
                                  assign primary = 'VEST'
                                  assign secondary = 'NCGA'
                                when 'cga-life-jacket'
                                  assign primary = 'JACKET'
                                  assign secondary = 'CGA'
                                when 'kneeboard'
                                  assign primary = 'KNEEBOARD'
                                  assign secondary = 'BOAT & CABLE'
                                when 'rope-wakeboard'
                                  assign primary = 'ROPE'
                                  assign secondary = 'WAKEBOARD'
                                when 'wake-surfer'
                                  assign primary = 'WAKESURF'
                                  assign secondary = 'BOARDS'
                                when 'rope-surf'
                                  assign primary = 'ROPE'
                                  assign secondary = 'SURF'
                                when 'wake-foil'
                                  assign primary = 'FOIL'
                                  assign secondary = 'WAKE'
                                when 'all-bags'
                                  assign primary = 'BAGS'
                                  assign secondary = 'GEAR'
                                when 'ski'
                                  assign primary = 'SKI'
                                  assign secondary = 'WATER'
                                when 'ski-boots'
                                  assign primary = 'BOOTS'
                                  assign secondary = 'SKI'
                                when 'rope-ski'
                                  assign primary = 'ROPE'
                                  assign secondary = 'SKI'
                                when 'towables'
                                  assign primary = 'TOWABLE'
                                  assign secondary = 'TUBES'
                                when 'paddleboards'
                                  assign primary = 'PADDLE'
                                  assign secondary = 'BOARDS'
                                when 'kayaks'
                                  assign primary = 'KAYAKS'
                                  assign secondary = 'INFLATABLE'
                                when 'inflatable-docks'
                                  assign primary = 'DOCKS'
                                  assign secondary = 'INFLATABLE'
                                when 'wetsuits'
                                  assign primary = 'WETSUITS'
                                  assign secondary = 'NEOPRENE'
                                when 'apparel'
                                  assign primary = 'APPAREL'
                                  assign secondary = 'RIDER'
                                when 'spare-parts'
                                  assign primary = 'PARTS'
                                  assign secondary = 'SPARE'
                              endcase
                            endif

                            # 3) Fallback: auto-build from title if anything is still empty
                            if primary == '' or secondary == ''
                              assign words = loop_collection.title | strip | split: ' '
                              assign words_count = words | size

                              if words_count > 1
                                assign last_index = words_count | minus: 1
                                assign last_word = words[last_index]
                                assign rest = ''

                                for w in words
                                  if forloop.index0 < last_index
                                    if rest != ''
                                      assign rest = rest | append: ' '
                                    endif
                                    assign rest = rest | append: w
                                  endif
                                endfor

                                if primary == ''
                                  assign primary = last_word | upcase
                                endif

                                if secondary == ''
                                  assign secondary = rest | upcase
                                endif
                              else
                                if primary == ''
                                  assign primary = loop_collection.title | upcase
                                endif

                                if secondary == ''
                                  assign secondary = 'SHOP ALL'
                                endif
                              endif
                            endif
                          -%}

                          <h3 class="collection-primary">
                            {{ primary }}
                          </h3>
                          <p class="collection-secondary">
                            {{ secondary }}
                          </p>
                        </div>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>
              </div>

              <div class="slider-nav slider-nav--floating desktop-only no-js-hidden">
                <button
                  type="button"
                  class="slider-nav__btn has-ltr-icon"
                  name="prev"
                  aria-controls="slider-{{ section.id }}"
                >
                  <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
                  {%- render 'icon-chevron-left', stroke_width: 1.3 -%}
                </button>
                <button
                  type="button"
                  class="slider-nav__btn has-ltr-icon"
                  name="next"
                  aria-controls="slider-{{ section.id }}"
                >
                  <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
                  {%- render 'icon-chevron-right', stroke_width: 1.3 -%}
                </button>
              </div>
            </carousel-slider>
          </div>
        </div>
      </div>

      {% unless section.settings.rel_coll_gall_full_width %}
        </div>
      {% endunless %}
    {% endif %}
  {% endcapture %}
{%- endif -%}

{% if header_image_enabled %}
  {%- liquid
    assign show_header = false
    if section.settings.show_title
      assign show_header = true
    endif
    if collection.description != blank and section.settings.coll_desc_pos == 'above'
      assign show_header = true
    endif
    if related_collections_count > 0 and section.settings.related_collections_style == 'buttons'
      assign show_header = true
    endif
  -%}
  {%- if show_header -%}
    <div class="page-header page-header--with-background img-fill image-overlay image-overlay--bg-{{ section.settings.overlay_style }} page-header--padded-{{ section.settings.heading_image_height }}">
      <div class="image-overlay__image">
        {%- render 'image' with collection.image, loading: 'eager', fetchpriority: 'high' -%}
      </div>
      <div class="text-overlay text-overlay--inline text-overlay--v-center text-overlay--h-center image-overlay__over" data-cc-animate data-cc-animate-delay="0.2s">
        <div class="text-overlay__inner">
          <div class="text-overlay__text">
            {% comment %} Collection title removed – we rely on highlighted tile in carousel {% endcomment %}

            {% if collection.description != blank and section.settings.coll_desc_pos == 'above' %}
              <div class="text-overlay__rte rte cf align-center reading-width large-text">{{ collection.description }}</div>
            {% endif %}

            {%- if related_collections_count > 0 and section.settings.related_collections_style == 'buttons' -%}
              {{ related_collection_html }}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
{% else %}
  {{ related_collection_html }}
  {%- liquid
    assign show_header = false
    if section.settings.show_title
      assign show_header = true
    endif
    if collection.description != blank and section.settings.coll_desc_pos == 'above'
      assign show_header = true
    endif
  -%}
  {%- if show_header -%}
    <div class="page-header page-header--with-upper-spacing">
      <div class="container">
        {% comment %} Collection title removed – carousel handles naming/highlight {% endcomment %}

        {% if collection.description != blank and section.settings.coll_desc_pos == 'above' %}
          <div class="rte cf align-center reading-width">{{ collection.description }}</div>
        {% endif %}
      </div>
    </div>
  {% endif %}
{% endif %}

  {%- if related_collections_count > 0 and header_image_enabled and section.settings.related_collections_style != 'buttons' -%}
    {{ related_collection_html }}
  {%- endif -%}

  <div class="container{% if settings.use_fullwidth_layout %} container--no-max{% endif %}{% if show_header == false %} lightly-spaced-row-above{% endif %}">
    <div class="utility-bar" data-ajax-container data-ajax-scroll-to>
      <div class="utility-bar__left">
        {% if section.settings.show_sort or show_filters %}
          <a href="#" class="toggle-btn utility-bar__item{% if section.settings.collapse_tag_sidebar_by_default == false %} toggle-btn--revealed-desktop{% endif %}{% if show_filters == false %} mobile-only{% endif %}" data-toggle-filters>
            <span class="btn-icon">{% render 'icon-filter' %}</span>
            <span>{{ 'products.filtering.filter' | t }}</span>
            {% liquid
              assign filter_count = 0
              for filter in collection.filters
                assign filter_count = filter_count | plus: filter.active_values.size
                if filter.type == 'price_range'
                  if filter.min_value.value != nil or filter.max_value.value != nil
                    assign filter_count = filter_count | plus: 1
                  endif
                endif
              endfor
            %}
            {% if filter_count > 0 %}
              <span class="toggle-btn__count">({{ filter_count }})</span>
            {% endif %}
            <span class="toggle-btn__chevron has-motion has-ltr-icon">{% render 'icon-chevron-right', stroke_width: 1.3 %}</span>
          </a>
        {% endif %}
      </div>

      {% if section.settings.show_total and paginate.items > 0 %}
        <div class="utility-bar__centre">
          <div class="utility-bar__item">{{ 'sections.collection.product_count' | t: count: paginate.items }}</div>
        </div>
      {% endif %}

      <div class="utility-bar__right">
        {% if section.settings.show_sort %}
          <span class="utility-bar__item desktop-only">
            <link-dropdown class="link-dropdown link-dropdown--right-aligned">
              <div class="visually-hidden" id="sort-dropdown-heading">{{ 'products.sorting.sort_by_label' | t | escape }}</div>
              <button class="link-dropdown__button has-motion" aria-expanded="false" aria-controls="sort-dropdown-options" aria-describedby="sort-dropdown-heading">
                <span class="link-dropdown__button-text">
                  {%- for option in collection.sort_options -%}
                    {%- if current_sort == option.value -%}
                      {{ option.name | escape }}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                </span>
                <span class="link-dropdown__button-icon has-motion">{% render 'icon-chevron-down', stroke_width: 1.3 %}</span>
              </button>
              <div class="link-dropdown__options" id="sort-dropdown-options">
                {%- for option in collection.sort_options -%}
                  {%- liquid
                    if section.settings.sort_show_featured == false and option.value == 'manual' and collection.default_sort_by != 'manual'
                      continue
                    endif
                    if section.settings.sort_show_best == false and option.value == 'best-selling' and collection.default_sort_by != 'best-selling'
                      continue
                    endif
                    if section.settings.sort_show_alpha == false and option.value == 'title-ascending' and collection.default_sort_by != 'title-ascending'
                      continue
                    endif
                    if section.settings.sort_show_alpha == false and option.value == 'title-descending' and collection.default_sort_by != 'title-descending'
                      continue
                    endif
                    if section.settings.sort_show_price == false and option.value == 'price-ascending' and collection.default_sort_by != 'price-ascending'
                      continue
                    endif
                    if section.settings.sort_show_price == false and option.value == 'price-descending' and collection.default_sort_by != 'price-descending'
                      continue
                    endif
                    if section.settings.sort_show_date == false and option.value == 'created-ascending' and collection.default_sort_by != 'created-ascending'
                      continue
                    endif
                    if section.settings.sort_show_date == false and option.value == 'created-descending' and collection.default_sort_by != 'created-descending'
                      continue
                    endif
                  -%}
                  <a href="{{ request.path | sort_by: option.value | escape }}" class="link-dropdown__link{% if current_sort == option.value %} link-dropdown__link--active{% endif %}">{{ option.name | escape }}</a>
                {%- endfor -%}
              </div>
            </link-dropdown>
          </span>
        {% endif %}
        <span class="utility-bar__item mobile-only">
          <div class="layout-switchers">
            <a class="layout-switch layout-switch--two-columns{% if settings.prod_thumb_mob_per_row == '2' %} layout-switch--active{% endif %}" href="#" aria-label="{{ 'sections.collection.grid_layout' | t }}">{%- render 'icon-grid', stroke_width: 1.3 -%}</a>
            <a class="layout-switch layout-switch--one-column{% if settings.prod_thumb_mob_per_row == '1' %} layout-switch--active{% endif %}" href="#" aria-label="{{ 'sections.collection.list_layout' | t }}">{%- render 'icon-box', stroke_width: 1.3 -%}</a>
          </div>
        </span>
      </div>
    </div>

    <filter-container class="filter-container filter-container--side{% if section.settings.collapse_tag_sidebar_by_default == false %} filter-container--show-filters-desktop{% endif %}" data-ajax-filtering="{{ settings.ajax_products }}" data-filter-section-id="{{ section.id }}">
      {% if section.settings.show_sort or show_filters %}
        {% render 'faceted-filters', filter_context: collection, clear_url: collection.url, current_sort: current_sort %}
      {% endif %}

      <div class="filters-adjacent collection-listing" data-ajax-container>
        {% if collection.products.size == 0 %}
          <h5 class="align-centre fully-spaced-row">{{ 'sections.collection.empty' | t }}</h5>
        {% else %}
          <div class="product-grid product-grid--per-row-{{ section.settings.grid }} product-grid--per-row-mob-{{ settings.prod_thumb_mob_per_row }} product-grid--per-row-mob-{{ settings.prod_thumb_mob_per_row }}">
            {%- liquid
              if settings.prod_thumb_shape == 'portrait-23'
                assign chosen_aspect_ratio = 0.67
              elsif settings.prod_thumb_shape == 'portrait-45'
                assign chosen_aspect_ratio = 0.8
              elsif settings.prod_thumb_shape == 'square'
                assign chosen_aspect_ratio = 1.0
              elsif settings.prod_thumb_shape == 'landscape-54'
                assign chosen_aspect_ratio = 1.25
              elsif settings.prod_thumb_shape == 'landscape-32'
                assign chosen_aspect_ratio = 1.50
              elsif settings.prod_thumb_shape == 'tallest'
                assign chosen_aspect_ratio = 99
                for product in collection.products
                  if product.featured_media.preview_image.aspect_ratio < chosen_aspect_ratio
                    assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
                  endif
                endfor
              else
                assign chosen_aspect_ratio = 0
                for product in collection.products
                  if product.featured_media.preview_image.aspect_ratio > chosen_aspect_ratio
                    assign chosen_aspect_ratio = product.featured_media.preview_image.aspect_ratio
                  endif
                endfor
              endif

              for product in collection.products
                assign prioritised_loading = false
                if forloop.index0 < section.settings.grid
                  assign prioritised_loading = true
                endif
                render 'product-block', product: product, custom_aspect_ratio: chosen_aspect_ratio, animate: true, prioritised_loading: prioritised_loading
              endfor
            -%}
          </div>
        {% endif %}
      </div>
    </filter-container>
  </div>

  <div class="container pagination-row" data-ajax-container>{% render 'pagination-control', paginate: paginate %}</div>

  {% endpaginate %}

  {% if collection.description != blank and section.settings.coll_desc_pos == 'below' %}
    <div class="container container--reading-width fully-spaced-row" data-cc-animate>
      <div class="rte cf">{{ collection.description }}</div>
    </div>
  {% endif %}
</div>

<script>
  (function() {
    function initSafewakeRelatedCarouselState() {
      var slider = document.getElementById('slider-{{ section.id }}');
      if (!slider || typeof window === 'undefined' || !window.sessionStorage) return;

      var storageKeyScroll = 'sfw_related_carousel_scroll';
      var storageKeyFlag   = 'sfw_related_carousel_from_carousel';

      var shouldRestore = false;
      var savedScroll   = 0;

      // Check if we SHOULD restore (only when we came from this carousel)
      try {
        var flag = sessionStorage.getItem(storageKeyFlag);
        if (flag === '1') {
          var saved = sessionStorage.getItem(storageKeyScroll);
          if (saved !== null) {
            var scroll = parseFloat(saved);
            if (!isNaN(scroll)) {
              savedScroll = scroll;
              shouldRestore = true;
            }
          }
        }
      } catch (e) {
        /* ignore */
      }

      // One-time use: clear keys so it doesn't stick forever
      try {
        sessionStorage.removeItem(storageKeyFlag);
        sessionStorage.removeItem(storageKeyScroll);
      } catch (e) {
        /* ignore */
      }

      // If flagged, restore scroll WITHOUT smooth animation (no flicker)
      if (shouldRestore) {
        var prevBehavior = slider.style.scrollBehavior;
        // Temporarily disable smooth scroll (overrides CSS)
        slider.style.scrollBehavior = 'auto';
        slider.scrollLeft = savedScroll || 0;
        // Force layout so the browser applies position before we restore smoothness
        void slider.offsetHeight;
        // Restore previous inline value (or clear to use CSS)
        if (prevBehavior) {
          slider.style.scrollBehavior = prevBehavior;
        } else {
          slider.style.scrollBehavior = '';
        }
      }

      // When user clicks any collection tile in this carousel,
      // remember the current scroll for the NEXT page load.
      var links = slider.querySelectorAll('.collection-link');
      links.forEach(function(link) {
        link.addEventListener('click', function() {
          try {
            sessionStorage.setItem(storageKeyScroll, String(slider.scrollLeft || 0));
            sessionStorage.setItem(storageKeyFlag, '1');
          } catch (e) {
            /* ignore */
          }
        });
      });

      // Hook arrows to move by ~2 cards per click (smooth within the page)
      var navButtons = document.querySelectorAll('[aria-controls="slider-{{ section.id }}"]');
      var firstItem  = slider.querySelector('.collection-item');
      var cardWidth  = firstItem ? firstItem.getBoundingClientRect().width : 0;

      navButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (!cardWidth) return;
          var dir = btn.getAttribute('name') === 'next' ? 1 : -1;
          slider.scrollBy({
            left: dir * cardWidth * 2,
            behavior: 'smooth'
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSafewakeRelatedCarouselState);
    } else {
      initSafewakeRelatedCarouselState();
    }
  })();
</script>

