<div class="section-signup {% if section.settings.color_scheme != 'default' %}use-color-scheme use-color-scheme--{{ section.settings.color_scheme }}{% endif %}">
  <div class="container strongly-padded-row align-center" data-cc-animate data-cc-animate-delay="0.3s">

    <h2 class="hometitle h4 in-content">{{ section.settings.title | escape }}</h2>

    <div class="rte lightly-spaced-row">{{ section.settings.subheading }}</div>

    <div class="signup-form">
      {% form 'customer', id: 'home_newsletter_signup' %}
        {% if form.posted_successfully? %}
          <div class="signup-form__response signup-form__response--success">
            <h4>{{ 'newsletter.success' | t }}</h4>
          </div>
        {% else %}
          {% if form.errors %}
            <div class="signup-form__response signup-form__response--error">
              {% for field in form.errors %}
                <p class="error">{{ field | capitalize }} - {{ form.errors.messages[field] }}</p>
              {% endfor %}
            </div>
          {% endif %}
          <input type="hidden" name="contact[tags]" value="prospect,newsletter"/>
          <div class="signup-form__inline-container">
            <input type="email"
              placeholder="{{ 'newsletter.placeholder' | t }}"
              class="signup-form__email"
              value=""
              name="contact[email]"
              aria-label="{{ 'newsletter.label' | t }}"
              required />
            <button class="btn signup-form__button" type="submit">
              {{- 'newsletter.button_label' | t -}}
            </button>
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>

{% style %}
  /* ── SafeWake Newsletter — Apple-style refinements ── */
  .section-newsletter {
    background: var(--sw-surface-section, #101218);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-newsletter .hometitle {
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--sw-text-primary, #F5F5F5);
  }

  .section-newsletter .rte {
    color: var(--sw-text-muted, #9CA1AB);
    max-width: 28rem;
    margin-inline: auto;
  }

  .section-newsletter .signup-form__inline-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 28rem;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .section-newsletter .signup-form__inline-container {
      flex-direction: row;
    }
  }

  .section-newsletter .signup-form__email {
    flex: 1;
    height: 48px;
    border-radius: 9999px;
    padding-inline: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--sw-text-primary, #F5F5F5);
    font-size: 16px; /* 16px prevents iOS zoom on focus */
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .section-newsletter .signup-form__email:focus {
    outline: none;
    border-color: hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.5);
    box-shadow: 0 0 0 3px hsla(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%), 0.15);
  }

  .section-newsletter .signup-form__email::placeholder {
    color: var(--sw-text-muted, #9CA1AB);
  }

  .section-newsletter .signup-form__button {
    height: 48px;
    padding-inline: 32px;
    border-radius: 9999px;
    background: var(--sw-text-primary, #F5F5F5);
    color: var(--sw-surface-void, #07090D);
    font-size: 14px;
    font-weight: 500;
    border: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .section-newsletter .signup-form__button:hover {
    background: rgba(245, 245, 245, 0.9);
    transform: translateY(-1px);
  }

  .section-newsletter .signup-form__response--success {
    color: var(--sw-stock-in, #22C55E);
  }

  .section-newsletter .signup-form__response--error .error {
    color: var(--sw-destructive, #B91C1C);
  }
{% endstyle %}

{% schema %}
{
  "name": "Newsletter",
  "class": "section-newsletter",
  "disabled_on": {
    "groups": [
      "aside"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Subscribe to our newsletter"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Promotions, new products and sales. Directly to your inbox.</p>"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "Customers who subscribe will have their email address added to the “accepts marketing” [customer list](/admin/customers?query=&accepts_marketing=1)"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
      }
    }
  ]
}
{% endschema %}
