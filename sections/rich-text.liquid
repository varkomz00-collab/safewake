{% style %}
  /* Apple-inspired compact rich text layout, scoped to this section only */
  #section-{{ section.id }}.section-rich-text--apple {
    --rt-apple-max-width: 720px;
    --rt-apple-body-size: 0.95rem;
    --rt-apple-eyebrow-size: 0.75rem;
    --rt-apple-muted-opacity: 0.7;
  }

  #section-{{ section.id }} .rt-apple-inner {
    max-width: var(--rt-apple-max-width);
    margin-left: auto;
    margin-right: auto;
  }

  #section-{{ section.id }} .rt-apple__eyebrow {
    font-size: var(--rt-apple-eyebrow-size);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: var(--rt-apple-muted-opacity);
    margin-bottom: 0.2rem;
  }

  #section-{{ section.id }} .rt-apple__title {
    margin: 0;
    letter-spacing: -0.01em;
  }

  #section-{{ section.id }} .rt-apple__text {
    font-size: var(--rt-apple-body-size);
    line-height: 1.5;
    max-width: 60ch;
  }

  #section-{{ section.id }} .rt-apple__actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  #section-{{ section.id }} .rt-apple__actions .button-row__btn {
    min-width: auto;
    white-space: nowrap;
  }

  #section-{{ section.id }} .rt-apple__actions .button-row__btn:first-child {
    font-weight: 500;
  }

  #section-{{ section.id }} .rt-apple__media {
    border-radius: 18px;
    overflow: hidden;
  }

  #section-{{ section.id }} .rt-apple__media img,
  #section-{{ section.id }} .rt-apple__media .placeholder-image {
    display: block;
    width: 100%;
    height: auto;
  }

  #section-{{ section.id }} .rt-apple__icon .large-light-icon {
    font-size: 1.75rem;
  }

  #section-{{ section.id }} .rt-apple__countdown {
    padding: 0.75rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  @media (max-width: 767.98px) {
    #section-{{ section.id }}.section-rich-text--apple {
      --rt-apple-max-width: 100%;
    }

    #section-{{ section.id }} .rt-apple__actions {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<div id="section-{{ section.id }}" class="{% if section.settings.color_scheme != 'default' %}use-color-scheme use-color-scheme--{{ section.settings.color_scheme }} fully-padded-row--{{ section.settings.height }}{% else %}fully-spaced-row--{{ section.settings.height }}{% endif %} section-rich-text--apple" data-cc-animate>
  <div class="container{% unless section.settings.full_width %} container--reading-width{% endunless %}">
    <div class="align-ltr-{{ section.settings.text_alignment }} spaced-column rt-apple-inner">
      {% assign skip_block_count = 0 %}
      {% for block in section.blocks %}
        {%- liquid
          if skip_block_count > 0
            assign skip_block_count = skip_block_count | minus: 1
            continue
          endif
        -%}
        {% case block.type %}

          {% when 'heading' %}
            {% if block.settings.use_h1 %}
              <h1 class="majortitle in-content rt-apple__title" {{ block.shopify_attributes }}>{{ block.settings.title | escape }}</h1>
            {% else %}
              <h2 class="majortitle in-content h1 rt-apple__title" {{ block.shopify_attributes }}>{{ block.settings.title | escape }}</h2>
            {% endif %}

          {% when 'subheading' %}
            <div class="subheading subheading--over lightish-spaced-row-above rt-apple__eyebrow" {{ block.shopify_attributes }}>
              {{ block.settings.subheading | escape }}
            </div>

          {% when 'text' %}
            <div class="rte lightly-spaced-row rt-apple__text {% if block.settings.enlarge_text %}large-text{% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {% when 'button' %}
            <div class="lightly-spaced-row button-row rt-apple__actions" {{ block.shopify_attributes }}>
              <a
                class="{% if block.settings.button_style != 'link' %}btn btn--{{ block.settings.button_style }}{% else %}small-feature-link{% endif %} button-row__btn"
                href="{{ block.settings.button_link }}"
              >
                {{ block.settings.button_label | escape }}
              </a>
              {%- assign skip_block_count = 0 -%}
              {%- for next_block in section.blocks offset: forloop.index -%}
                {%- if next_block.type == 'button' -%}
                  {%- assign skip_block_count = skip_block_count | plus: 1 -%}
                  <a
                    class="{% if next_block.settings.button_style != 'link' %}btn btn--{{ next_block.settings.button_style }}{% else %}small-feature-link{% endif %} button-row__btn"
                    href="{{ next_block.settings.button_link }}"
                    {{ next_block.shopify_attributes }}
                  >
                    {{ next_block.settings.button_label | escape }}
                  </a>
                {%- else -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            </div>

          {% when 'image' %}
            <div
              class="lightly-spaced-row lightish-spaced-row-above inline-width-container rt-apple__media"
              style="width: {{ block.settings.image_width }}px"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.url != blank %}<a href="{{ block.settings.url }}">{% endif %}
                {% if block.settings.image != blank %}
                  {%- liquid
                    assign image_sizes = block.settings.image_width | append: 'px'
                    assign image_widths = block.settings.image_width | times: 2 | prepend: ', ' | prepend: block.settings.image_width
                    render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
                  -%}
                {% else %}
                  <div class="placeholder-image">
                    {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
                  </div>
                {% endif %}
              {% if block.settings.url != blank %}</a>{% endif %}
            </div>

          {% when 'icon' %}
            <div class="lightly-spaced-row rt-apple__icon" {{ block.shopify_attributes }}>
              <span class="large-light-icon">
                {% render 'icon', icon: block.settings.icon, size: 'medium' %}
              </span>
            </div>

          {%- when 'countdown' -%}
            <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
            {% style %}
              .block-id-{{ block.id }} .countdown {
                --countdown-desktop-size: {{ block.settings.number_size }}px;
              }
            {% endstyle %}

            <div class="block-id-{{ block.id }} lightly-spaced-row lightish-spaced-row-above countdown-font-{{ block.settings.number_font }} countdown-divider-{{ block.settings.divider_type }} rt-apple__countdown" {{ block.shopify_attributes }}>
              {% render 'countdown-timer',
                end_date: block.settings.end_date,
                end_time: block.settings.end_time,
                end_text: block.settings.end_text,
                end_midnight: true,
                hide_on_end: block.settings.hide_on_end,
                show_labels: block.settings.show_timer_labels
              %}
            </div>

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>


