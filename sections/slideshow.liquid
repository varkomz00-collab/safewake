{%- if section.blocks.size > 1 -%}
  <script src="{{ 'slideshow.js' | asset_url }}" defer></script>
{%- endif -%}

<div id="section-id-{{ section.id }}" data-cc-animate data-cc-animate-delay="0.2s">
  {% style %}
    {%- if section.settings.autoplay -%}
      #section-id-{{ section.id }} slide-show {
        --duration: {{ section.settings.autoplay_speed }}s;
        --play-state: paused;
      }
    {%- endif -%}

    /* Min-height matching Lovable min-h-[420px] */
    #section-id-{{ section.id }} .image-overlay {
      min-height: 420px;
    }

    {%- if section.settings.height == 'fixed' %}
      #section-id-{{ section.id }} .height--fixed {
        --image-height: {{ section.settings.height_mobile }}px;
      }

      @media (min-width: 768px) {
        #section-id-{{ section.id }} .height--fixed {
          --image-height: {{ section.settings.height_desktop }}px;
        }
      }
    {%- endif -%}

    {%- if section.settings.height == 'adapt' %}
      #section-id-{{ section.id }} .height--adapt {
        {%- if section.blocks.first.settings.mobile_image -%}
          --aspect-ratio: {{ section.blocks.first.settings.mobile_image.aspect_ratio }};
        {%- else -%}
          --aspect-ratio: {{ section.blocks.first.settings.image.aspect_ratio | default: 2.0 }};
        {%- endif -%}
      }
      {%- if section.blocks.first.settings.mobile_image -%}
      @media (min-width: 768px) {
        #section-id-{{ section.id }} .height--adapt {
          --aspect-ratio: {{ section.blocks.first.settings.image.aspect_ratio | default: 2.0 }};
        }
      }
      {%- endif -%}
    {%- endif -%}

    {%- for block in section.blocks -%}
      #section-id-{{ section.id }} .slide-{{ forloop.index }} .text-overlay__title {
        font-size: {{ block.settings.title_size_mobile }}px;
        {%- if block.settings.title_size_mobile >= 90 -%}
        line-height: 1em;
        {%- endif -%}
      }
    {%- endfor -%}

    @media (min-width: 768px) {
      {%- for block in section.blocks -%}
      #section-id-{{ section.id }} .slide-{{ forloop.index }} .text-overlay__title {
        {%- assign title_size_medium = block.settings.title_size | times: 0.7 | at_least: block.settings.title_size_mobile -%}
        font-size: {{ title_size_medium }}px;
        {%- if title_size_medium >= 90 -%}
        line-height: 1em;
        {%- endif -%}
      }
      {%- endfor -%}
    }

    @media (min-width: 1100px) {
      {%- for block in section.blocks -%}
      #section-id-{{ section.id }} .slide-{{ forloop.index }} .text-overlay__title {
        font-size: {{ block.settings.title_size }}px;
        {%- if block.settings.title_size >= 90 -%}
        line-height: 1em;
        {%- endif -%}
      }
      {%- endfor -%}
    }

    /* -------------------------------
       Apple-style refinements
       (scoped only to this section)
       ------------------------------- */

    #section-id-{{ section.id }} {
      --slideshow-radius: 22px;
      --slideshow-glass-bg: 8, 10, 14;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} {
        --slideshow-radius: 28px;
      }
    }

    #section-id-{{ section.id }} .slideshow {
      border-radius: var(--slideshow-radius);
      overflow: hidden;
    }

    /* 1. Hero height: responsive svh/vh with min/max */
    #section-id-{{ section.id }} .slideshow__slide {
      min-height: 420px;
      max-height: 800px;
      height: 75svh;
      height: 75vh; /* fallback */
    }

    @supports (height: 1svh) {
      #section-id-{{ section.id }} .slideshow__slide {
        height: 75svh;
      }
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .slideshow__slide {
        height: 70vh;
      }
    }

    @media (min-width: 1100px) {
      #section-id-{{ section.id }} .slideshow__slide {
        height: 65vh;
      }
    }

    /* 2. Gradient overlay: bottom-only, preserves image top */
    #section-id-{{ section.id }} .image-overlay__image::after {
      content: “”;
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 50%);
    }

    #section-id-{{ section.id }} .image-overlay__image {
      position: relative;
    }

    /* 7. Smooth slide transitions: 700ms for content feel */
    #section-id-{{ section.id }} .slideshow__slide {
      transition: opacity 700ms cubic-bezier(0.4, 0, 0.2, 1), transform 700ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    #section-id-{{ section.id }} .slideshow__slide.is-active {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }

    #section-id-{{ section.id }} .slideshow__slide:not(.is-active) {
      opacity: 0.4;
      transform: translate3d(0, 0, 0) scale(0.995);
    }

    /* Text block: compact, readable, “one decision” feel */
    #section-id-{{ section.id }} .text-overlay__inner {
      max-width: 44rem;
      padding-inline: 20px;
      padding-bottom: 32px;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .text-overlay__inner {
        padding-inline: 32px;
        padding-bottom: 40px;
      }
    }

    /* 6. Typography: heading with tight tracking */
    #section-id-{{ section.id }} .text-overlay__title {
      letter-spacing: -0.04em;
      font-weight: 600;
      line-height: 1.25;
    }

    /* 6. Typography: subheading as eyebrow */
    #section-id-{{ section.id }} .text-overlay__subheading {
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-size: 10px;
      font-weight: 500;
      opacity: 0.7;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .text-overlay__subheading {
        font-size: 12px;
      }
    }

    #section-id-{{ section.id }} .text-overlay__button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    @media (max-width: 767.98px) {
      #section-id-{{ section.id }} .text-overlay__button-row {
        justify-content: flex-start;
      }
    }

    /* 5. CTA button: pill shape, glass effect, white border, 44px touch target */
    #section-id-{{ section.id }} .text-overlay__button.btn {
      position: relative;
      border-radius: 999px;
      min-height: 44px;
      padding-inline: 1.7em;
      padding-block: 0.7em;
      border: 1px solid rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.2);
      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.55),
        0 0 0 1px rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      font-weight: 500;
      font-size: 12px;
      letter-spacing: 0;
      text-transform: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      color: #ffffff;
      transition:
        transform 300ms ease,
        box-shadow 300ms ease,
        background 300ms ease,
        border-color 300ms ease,
        opacity 300ms ease,
        color 300ms ease;
    }

    #section-id-{{ section.id }} .text-overlay__button-row .text-overlay__button.btn:nth-child(2) {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
        rgba(10, 10, 12, 0.82);
      border-color: rgba(255, 255, 255, 0.10);
      box-shadow: 0 10px 26px rgba(0, 0, 0, 0.5);
      opacity: 0.92;
    }

    @media (hover: hover) {
      #section-id-{{ section.id }} .text-overlay__button.btn:hover {
        transform: translateY(-1px);
        box-shadow:
          0 22px 50px rgba(0, 0, 0, 0.65),
          0 0 0 1px rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.28);
        background: #ffffff;
        color: #000000;
      }
    }

    #section-id-{{ section.id }} .text-overlay__button.btn:focus-visible {
      outline: 2px solid hsl(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%));
      outline-offset: 2px;
    }

    #section-id-{{ section.id }} .text-overlay__button.btn:active {
      transform: translateY(0);
      box-shadow:
        0 8px 26px rgba(0, 0, 0, 0.7),
        0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    @media (min-width: 640px) {
      #section-id-{{ section.id }} .text-overlay__button.btn {
        font-size: 14px;
        padding-inline: 24px;
        padding-block: 10px;
      }
    }

    /* 3. Dot navigation: pill-expand active state (Lovable pattern) */
    #section-id-{{ section.id }} .slideshow-pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      margin-top: 8px;
    }

    @media (min-width: 768px) {
      #section-id-{{ section.id }} .slideshow-pagination {
        margin-top: 24px;
      }
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn {
      position: relative;
      min-width: 44px;
      min-height: 44px;
      padding: 0;
      border-radius: 999px;
      border: 0;
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn__circle {
      display: none;
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn::before {
      content: “”;
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: #ffffff;
      opacity: 0.3;
      transition: width 300ms cubic-bezier(0.4, 0, 0.2, 1), opacity 300ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn:hover::before {
      opacity: 0.5;
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn[aria-current=”true”]::before {
      width: 32px;
      opacity: 1;
    }

    #section-id-{{ section.id }} .slideshow-pagination .page-btn:focus-visible {
      outline: 2px solid rgba(255, 255, 255, 0.7);
      outline-offset: 3px;
    }

    /* 4. Arrow navigation: frosted glass, round, 44px touch targets */
    #section-id-{{ section.id }} .slideshow-nav__btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(8, 10, 14, 0.65);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      padding: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition:
        opacity 300ms ease,
        background 150ms ease-out,
        transform 150ms ease-out,
        box-shadow 150ms ease-out,
        border-color 150ms ease-out;
    }
    /* Desktop: arrows visible on hover only (pointer devices only) */
    @media (min-width: 768px) and (hover: hover) {
      #section-id-{{ section.id }} .slideshow-nav__btn {
        opacity: 0;
      }
      #section-id-{{ section.id }}:hover .slideshow-nav__btn {
        opacity: 1;
      }
    }

    @media (hover: hover) {
      #section-id-{{ section.id }} .slideshow-nav__btn:hover {
        background: rgba(12, 14, 18, 0.96);
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.56);
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.26);
      }
    }
    #section-id-{{ section.id }} .slideshow-nav__btn:focus-visible {
      outline: 2px solid hsl(var(--sw-glow-h, 205), var(--sw-glow-s, 100%), var(--sw-glow-l, 52%));
      outline-offset: 2px;
    }

    #section-id-{{ section.id }} .slideshow-nav__btn:active {
      transform: translateY(0);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.7);
    }

    /* Mobile “swipe” hint */
    #section-id-{{ section.id }} .slideshow-swipe-hint {
      margin-top: 0.75rem;
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      opacity: 0.68;
      display: none;
    }

    #section-id-{{ section.id }} .slideshow-swipe-hint__dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      display: inline-block;
      margin-right: 0.45rem;
      background: rgba(255, 255, 255, 0.7);
    }

    @media (max-width: 767.98px) {
      #section-id-{{ section.id }} .slideshow-swipe-hint {
        display: flex;
        align-items: center;
        justify-content: center;
      }
    }
  {% endstyle %}

  {%- unless section.settings.full_width -%}
    <div class="container container--not-mobile fully-spaced-row--medium fully-spaced-row--not-mobile">
  {%- endunless -%}

  <slide-show
    role="region"
    aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
    aria-label="{{ section.settings.accessibility_info | escape }}"
    data-autoplay="false"
    data-speed="{{ section.settings.autoplay_speed }}"
    data-transition="{{ section.settings.transition }}"
    data-transition-out-delay="0"
    data-pause-autoplay-on-mouseover="false"
  >
    <div class="slideshow slideshow--navigation-{{ section.settings.navigation }}" id="slideshow-{{ section.id }}" aria-live="polite" aria-atomic="true">
      {%- for block in section.blocks -%}
        {%- liquid
          assign show_overlay_text = false
          if block.settings.title != blank or block.settings.subheading != blank or block.settings.text != blank or block.settings.button_label_1 != blank or block.settings.button_label_2 != blank
            assign show_overlay_text = true
            assign wrap_slide_with_link = true
            if block.settings.slide_link == blank or block.settings.text contains '</a>' or block.settings.button_url_1 != blank or block.settings.button_url_2 != blank
              assign wrap_slide_with_link = false
            endif
          elsif block.settings.slide_link != blank
            assign wrap_slide_with_link = true
          endif
        -%}
        <image-with-text-overlay
          class="slideshow__slide slide-{{ forloop.index }}{% if forloop.first %} is-active{% endif %} height--{{ section.settings.height }} image-overlay image-overlay--bg-{{ section.settings.overlay_style }}{% if section.settings.mobile_overlay_under %} text-overlay-parent--mobile-stack{% endif %}"
          role="group"
          aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
          aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
          {%- unless forloop.first %}tabindex="-1"{% endunless -%}
          {%- if request.design_mode %}data-index="{{ forloop.index0 }}"{% endif -%}
          style="--slide-index: {{ forloop.index }}"
          {{ block.shopify_attributes }}
        >

          {%- if wrap_slide_with_link -%}
            <a class="image-overlay__image-link" href="{{ block.settings.slide_link }}">
          {%- endif -%}

          {%- if block.settings.image == blank -%}
            <div class="height__image image-overlay__image overflow-hidden">
              <div class="slideshow__motion-media has-motion placeholder-image{% if show_overlay_text %} dark{% endif %}">
                {%- capture current %}{% cycle 1, 2 %}{% endcapture -%}
                {{- 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg' -}}
              </div>
            </div>
          {%- else -%}

            {%- liquid
              assign loading = 'lazy'
              assign fetchpriority = nil
              if forloop.first
                if section.location == 'header' or section.location == 'template' and section.index == 1
                  assign loading = 'eager'
                  assign fetchpriority = 'high'
                endif
              endif
            -%}

            <div class="height__image image-overlay__image overflow-hidden">
              {%- render 'image-desktop-and-mobile',
                class: 'slideshow__motion-media has-motion',
                desktop_image: block.settings.image,
                mobile_image: block.settings.mobile_image,
                loading: loading,
                fetchpriority: fetchpriority,
                block: block
              -%}
            </div>
          {%- endif -%}

          {%- if show_overlay_text -%}
            <div class="text-overlay text-overlay--with-reveal text-overlay--for-banner text-overlay--v-{{ block.settings.text_alignment | split: ' ' | first }} text-overlay--h-{{ block.settings.text_alignment | split: ' ' | last }} image-overlay__over has-motion">
              <div class="text-overlay__inner" style="--heading-max-width: {{ block.settings.heading_max_width }}em">
                <div class="text-overlay__text slideshow__motion-overlay has-motion">
                  {%- if block.settings.subheading != blank -%}
                    <div class="text-overlay__reveal">
                      <div class="text-overlay__subheading subheading subheading--over has-motion">
                        {{ block.settings.subheading | escape }}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <div class="text-overlay__reveal">
                      {% if block.settings.use_h1 %}
                        <h1 class="text-overlay__title has-motion">
                          {% render 'multiline-text' with block.settings.title %}
                        </h1>
                      {% else %}
                        <h2 class="text-overlay__title h1 has-motion">
                          {% render 'multiline-text' with block.settings.title %}
                        </h2>
                      {% endif %}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="text-overlay__reveal">
                      <div class="text-overlay__rte rte {% if block.settings.enlarge_text %}large-text{% endif %} has-motion">
                        {{ block.settings.text }}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                    <div class="text-overlay__button-row">
                      {%- if wrap_slide_with_link -%}
                        {%- if block.settings.button_label_1 != blank -%}
                          <span class="text-overlay__button btn btn--secondary">
                            {{ block.settings.button_label_1 | escape }}
                          </span>
                        {%- endif -%}
                        {%- if block.settings.button_label_2 != blank -%}
                          <span class="text-overlay__button btn btn--secondary">
                            {{ block.settings.button_label_2 | escape }}
                          </span>
                        {%- endif -%}
                      {%- else -%}
                        {%- if block.settings.button_label_1 != blank -%}
                          <a class="text-overlay__button btn btn--secondary" href="{{ block.settings.button_url_1 }}">
                            {{ block.settings.button_label_1 | escape }}
                          </a>
                        {%- endif -%}
                        {%- if block.settings.button_label_2 != blank -%}
                          <a class="text-overlay__button btn btn--secondary" href="{{ block.settings.button_url_2 }}">
                            {{ block.settings.button_label_2 | escape }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if wrap_slide_with_link -%}
            </a>
          {%- endif -%}
        </image-with-text-overlay>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 and section.settings.navigation != 'none' -%}
      <div class="slideshow-ctrl js-only{% if section.settings.mobile_overlay_under %} slideshow-ctrl--mobile-stack{% endif %}">
        <div class="slideshow-pagination{% if section.settings.navigation == 'arrows' %} mobile-only{% endif %}">
          {%- for block in section.blocks -%}
            <button class="page-btn" data-index="{{ forloop.index0 }}" aria-controls="slideshow-{{ section.id }}"{% if forloop.first %} aria-current="true"{% endif %}>
              <span class="visually-hidden">
                {{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}
              </span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="page-btn__circle">
                <circle class="page-btn__fg-circle" cx="12" cy="12" r="6" />
                <circle class="page-btn__bg-circle" cx="12" cy="12" r="6" />
              </svg>
            </button>
          {%- endfor -%}
        </div>

        {%- if section.settings.navigation == 'arrows' -%}
          <div class="slideshow-nav desktop-only">
            <button type="button" class="slideshow-nav__btn has-ltr-icon" name="prev" aria-controls="slideshow-{{ section.id }}">
              <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
              {% render 'icon-chevron-left' %}
            </button>

            <button type="button" class="slideshow-nav__btn has-ltr-icon" name="next" aria-controls="slideshow-{{ section.id }}">
              <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
              {% render 'icon-chevron-right' %}
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </slide-show>

  <div class="slideshow-swipe-hint mobile-only" aria-hidden="true">
    <span class="slideshow-swipe-hint__dot"></span>
    <span class="slideshow-swipe-hint__label">Swipe to explore</span>
  </div>

  {%- unless section.settings.full_width -%}</div>{%- endunless -%}
</div>

<script>
  (function () {
    var section = document.getElementById('section-id-{{ section.id }}');
    if (!section) return;

    var slideShow = section.querySelector('slide-show');
    if (!slideShow) return;

    // Avoid double-binding (theme editor etc.)
    if (slideShow.__safewakeCustomAutoplayBound) return;
    slideShow.__safewakeCustomAutoplayBound = true;

    var shouldAutoplay = {{ section.settings.autoplay | json }};
    var autoplayDelay = {{ section.settings.autoplay_speed | times: 1000 }};

    if (!autoplayDelay || autoplayDelay < 500) {
      autoplayDelay = 500;
    }

    var autoplayTimer = null;

    function clearAutoplayTimer() {
      if (autoplayTimer !== null) {
        window.clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function getNextButton() {
      // Prefer the "next" arrow if it exists
      var nextArrow = section.querySelector('.slideshow-nav__btn[name="next"]');
      if (nextArrow) return nextArrow;

      // Fallback: use pagination dots
      var currentDot = section.querySelector('.slideshow-pagination .page-btn[aria-current="true"]');
      if (currentDot && currentDot.nextElementSibling) {
        return currentDot.nextElementSibling;
      }

      var firstDot = section.querySelector('.slideshow-pagination .page-btn');
      return firstDot || null;
    }

    function goToNextSlide() {
      var btn = getNextButton();
      if (!btn) return;
      btn.click();
    }

    function startAutoplay() {
      clearAutoplayTimer();

      if (!shouldAutoplay) {
        slideShow.style.setProperty('--play-state', 'paused');
        return;
      }

      slideShow.style.setProperty('--play-state', 'running');
      autoplayTimer = window.setInterval(goToNextSlide, autoplayDelay);
    }

    function pauseAutoplay() {
      clearAutoplayTimer();
      slideShow.style.setProperty('--play-state', 'paused');
    }

    // Kick off autoplay based on setting
    if (shouldAutoplay) {
      startAutoplay();
    } else {
      slideShow.style.setProperty('--play-state', 'paused');
    }

    // Reset timer on manual navigation
    var navButtons = section.querySelectorAll('.slideshow-nav__btn[name], .slideshow-pagination .page-btn');
    navButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!shouldAutoplay) return;
        startAutoplay();
      });
    });

    // Pause ONLY while hovering over the CTA buttons
    var ctaButtons = section.querySelectorAll('.text-overlay__button.btn');
    ctaButtons.forEach(function (btn) {
      btn.addEventListener('mouseenter', function () {
        pauseAutoplay();
      });

      btn.addEventListener('mouseleave', function () {
        if (shouldAutoplay) {
          startAutoplay();
        }
      });
    });
  })();
</script>

