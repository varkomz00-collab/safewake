<script>
  window.tamaraWidgetConfig = {
    lang: "{{ request.locale.iso_code }}",
    country: "AE",
    publicKey: "14b81517-6398-42d6-a160-b1f91f7f4e91",
    css: `
      /* Make the widget blend into the page and stop the white hover */
      :host {
        display: inline-block !important;
        color: inherit !important;
        background: transparent !important;
        background-color: transparent !important;
        border: 0 !important;
        box-shadow: none !important;
        font-family: inherit !important;
      }
      /* Nuke hover/focus background flip */
      :host(:hover), :host(:focus), :host(:active) {
        color: inherit !important;
        background: transparent !important;
        background-color: transparent !important;
        box-shadow: none !important;
      }

      /* Belt & suspenders: clear backgrounds on inner containers */
      .tamara-summary-widget,
      .tamara-summary-widget__container,
      .tamara-summary-widget__content,
      .tamara-summary-widget__main,
      .tamara-summary-widget__hover,
      .tamara-summary-widget__extra {
        background: transparent !important;
        background-color: transparent !important;
        border: 0 !important;
        box-shadow: none !important;
      }

      /* Keep the amount emphasized but inherit color */
      .tamara-summary-widget__amount {
        font-weight: 700 !important;
        color: inherit !important;
      }

      /* Links follow your page color */
      a { color: inherit !important; text-decoration: underline; }
    `,
    style: {
      fontSize: '14px',
      badgeRatio: 1.2,
    }
  }
</script>
<script defer src="https://cdn.tamara.co/widget-v2/tamara-widget.js"></script>

<!-- Optional: wrap to control text color (dark sites = white text) -->
<div style="color:#fff">
  <tamara-widget
    id="tamara-widget-custom"
    type="tamara-summary"
    amount="{{ product.price | money_without_currency | remove: ',' }}"
    config='{"badgePosition":"right","showExtraContent":""}'
    inline-type="2">
  </tamara-widget>
</div>
